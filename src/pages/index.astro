---
const advantages = [
  {
    title: "Local Network",
    description:
      "Direct relationships with landowners, advisors, and Andorran operators unlock faster access to qualified opportunities.",
  },
  {
    title: "Regulatory Expertise",
    description:
      "We navigate planning, approvals, and compliance in the Principality with disciplined local execution.",
  },
  {
    title: "Lifecycle Management",
    description:
      "From sourcing through delivery, we manage project decisions end-to-end with investor clarity at every stage.",
  },
];

const projects = [
  {
    name: "Escaldes Signature Residences",
    status: "Under Construction",
    value: "€34M",
    sector: "Luxury Residential",
    image:
      "https://images.unsplash.com/photo-1460317442991-0ec209397118?auto=format&fit=crop&w=1200&q=80",
  },
  {
    name: "La Massana Heights",
    status: "Pipeline",
    value: "€18M",
    sector: "Residential Development",
    image:
      "https://images.unsplash.com/photo-1482192505345-5655af888cc4?auto=format&fit=crop&w=1200&q=80",
  },
  {
    name: "Andorra Business Residence",
    status: "Pipeline",
    value: "€22M",
    sector: "Mixed-Use",
    image:
      "https://images.unsplash.com/photo-1512918728675-ed5a9ecdebfd?auto=format&fit=crop&w=1200&q=80",
  },
];

const localPartners = [
  { name: "DATA", logo: "/images/partners/DATA LOGO.png" },
  { name: "Emindset Law", logo: "/images/partners/Emindset LAW LOGO.png" },
  { name: "Govern d'Andorra", logo: "/images/partners/Govern d'Andorra logo.png" },
  { name: "Creand", logo: "/images/partners/creand.webp" },
  { name: "Engel & Volkers", logo: "/images/partners/engel volkers logo.png" },
];

const localPartnersLoop = [...localPartners, ...localPartners, ...localPartners, ...localPartners];
const currentYear = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Equity Partners | Andorra Property Group</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Open+Sans:wght@700&display=swap");

      :root {
        --bg-night: #06080c;
        --bg-paper: #f3f5f9;
        --bg-white: #ffffff;
        --text-primary: #1f2835;
        --text-muted: #5a667a;
        --text-light: #e8edf5;
        --accent: #8293ae;
        --line: #dbe1ea;
        --max-width: 1120px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Avenir Next", "Segoe UI", Arial, sans-serif;
        color: var(--text-primary);
        background: radial-gradient(circle at 10% -10%, #eef2f8 0, var(--bg-paper) 50%);
        line-height: 1.5;
      }

      .container {
        width: min(var(--max-width), 92vw);
        margin: 0 auto;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .hero {
        min-height: 84vh;
        padding: 2rem 0 3.5rem;
        background: linear-gradient(
            to bottom,
            rgba(6, 8, 12, 0.4) 0%,
            rgba(6, 8, 12, 0.26) 18%,
            rgba(6, 8, 12, 0.18) 34%,
            rgba(6, 8, 12, 0.3) 100%
          ),
          url("/hero-andorra-R2PtlkD-.jpg")
            center / cover no-repeat;
        color: var(--text-light);
        display: flex;
        flex-direction: column;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: nowrap;
        gap: 1.8rem;
        padding-top: 2.15rem;
        padding-bottom: 0.15rem;
        padding-left: calc((100vw - min(var(--max-width), 92vw)) / 2);
        padding-right: calc((100vw - min(var(--max-width), 92vw)) / 2);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        transform: none;
        width: 100%;
        z-index: 220;
        background: transparent !important;
        border-bottom: 1px solid transparent;
        border-radius: 0;
        transition: padding-top 320ms ease, padding-bottom 320ms ease, background-color 320ms ease,
          backdrop-filter 320ms ease, -webkit-backdrop-filter 320ms ease, border-color 320ms ease,
          box-shadow 320ms ease;
      }

      body.is-scrolled .site-header {
        background: rgba(15, 26, 42, 0.6) !important;
        padding-top: 1.25rem;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom-color: rgba(220, 231, 246, 0.2);
        box-shadow: 0 8px 20px rgba(6, 10, 18, 0.18);
      }

      @supports not ((backdrop-filter: blur(1px))) {
        body.is-scrolled .site-header {
          background: rgba(15, 26, 42, 0.84) !important;
        }
      }

      .logo {
        width: 180px;
        height: auto;
        position: relative;
        top: -5px;
        filter: brightness(0) invert(1);
        filter: brightness(0) invert(1) drop-shadow(0 1px 2px rgba(0, 0, 0, 0.5))
          drop-shadow(0 0 10px rgba(8, 14, 23, 0.35));
      }

      .main-nav {
        display: flex;
        align-items: center;
        margin-left: auto;
        flex-wrap: nowrap;
        gap: 1.3rem;
        position: relative;
        top: -4px;
        z-index: 121;
      }

      .menu-toggle-input {
        display: none;
      }

      .menu-toggle {
        display: none;
        width: 38px;
        height: 34px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 0.45rem;
        background: transparent;
        align-items: center;
        justify-content: center;
        cursor: pointer;
      }

      .menu-toggle-bars {
        display: block;
        width: 18px;
        height: 2px;
        background: #ffffff;
        position: relative;
        transition: background 220ms ease;
      }

      .menu-toggle-bars::before,
      .menu-toggle-bars::after {
        content: "";
        position: absolute;
        left: 0;
        width: 18px;
        height: 2px;
        background: #ffffff;
        transition: transform 220ms ease, top 220ms ease;
      }

      .menu-toggle-bars::before {
        top: -6px;
      }

      .menu-toggle-bars::after {
        top: 6px;
      }

      .menu-list {
        list-style: none;
        display: flex;
        align-items: center;
        flex-wrap: nowrap;
        white-space: nowrap;
        gap: 1.2rem;
        margin: 0;
        padding: 0;
      }

      .menu-link {
        display: inline-flex;
        align-items: center;
        color: #ffffff;
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        font-weight: 600;
        line-height: 1;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
      }

      .menu-link:hover {
        color: #d7e3f5;
      }

      .menu-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
        top: 1px;
        flex: 0 0 auto;
        min-width: 126px;
        color: #172235;
        background: rgba(204, 215, 232, 0.85);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        line-height: 1;
        border: 1px solid rgba(255, 255, 255, 0.15);
        white-space: nowrap;
        transition: background-color 180ms ease, transform 180ms ease, color 180ms ease;
      }

      .menu-cta:hover {
        background: rgba(224, 233, 246, 0.96);
        color: #101b2c;
        transform: translateY(-1px);
      }

      .menu-cta:focus-visible {
        outline: 2px solid rgba(234, 241, 252, 0.9);
        outline-offset: 2px;
      }

      .hero-content {
        margin-top: auto;
        max-width: 50rem;
        padding-top: 10rem;
        animation: rise 900ms 120ms ease both;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1 {
        margin: 0;
        font-family: "Open Sans", "Avenir Next", "Segoe UI", Arial, sans-serif;
        font-weight: 700;
        font-size: clamp(2rem, 5vw, 4rem);
        letter-spacing: 0.02em;
        line-height: 1.08;
      }

      .subline {
        margin-top: 0.9rem;
        max-width: 42rem;
        color: #cad4e4;
        font-size: clamp(1rem, 1.8vw, 1.2rem);
      }

      .hero-kicker {
        margin-top: 0;
        margin-bottom: 1.1rem;
        font-size: 0.78rem;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: #b2c0d4;
      }

      .section {
        padding: 4rem 0;
      }

      .partners-wrap {
        background: var(--bg-paper);
        border-bottom: 1px solid var(--line);
        padding: 2.2rem 0 2rem;
        overflow: hidden;
      }

      .partners-title {
        margin: 0 0 1.4rem;
        text-align: left;
        font-family: "Avenir Next", "Segoe UI", Arial, sans-serif;
        font-size: 0.8rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 400;
      }

      .partners-divider {
        width: 110px;
        height: 1px;
        margin: 0.85rem auto 1.3rem;
        background: #d8dee9;
      }

      .partners-marquee {
        position: relative;
        overflow: hidden;
        width: 100%;
      }

      .partners-track {
        display: flex;
        width: max-content;
        gap: 3rem;
        animation: partners-scroll 46s linear infinite;
      }

      .partner-logo-box {
        flex: 0 0 auto;
        width: 145px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.2rem 0.45rem;
      }

      .partner-logo-box img {
        max-width: 100%;
        max-height: 48px;
        width: auto;
        height: auto;
        filter: grayscale(100%) brightness(0.88);
        opacity: 0.9;
        transition: filter 200ms ease, opacity 200ms ease, transform 200ms ease;
      }

      .partner-logo-box:hover img {
        filter: grayscale(0%) brightness(0.98);
        opacity: 1;
        transform: translateY(-1px);
      }

      @keyframes partners-scroll {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-25%);
        }
      }

      .section-header {
        max-width: 48rem;
      }

      .eyebrow {
        font-size: 0.8rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.85rem;
      }

      h2 {
        font-size: clamp(1.55rem, 3vw, 2.45rem);
        line-height: 1.12;
      }

      .intro {
        margin-top: 0.9rem;
        color: var(--text-muted);
      }

      .adv-grid {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .adv-card {
        background: var(--bg-white);
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: 1.4rem;
      }

      .adv-number {
        font-size: 0.8rem;
        color: var(--accent);
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .adv-card h3 {
        margin-top: 0.5rem;
        font-size: 1.25rem;
      }

      .adv-card p {
        margin-top: 0.7rem;
        color: var(--text-muted);
      }

      .projects {
        background: linear-gradient(180deg, #f4f6fa, #edf1f7);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .project-grid {
        margin-top: 1.9rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .project-card {
        position: relative;
        border-radius: 1rem;
        overflow: hidden;
        min-height: 23rem;
        display: flex;
        align-items: flex-end;
        border: 1px solid #d7deea;
      }

      .project-card img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .project-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(10, 15, 24, 0.15), rgba(10, 15, 24, 0.86));
      }

      .project-meta {
        position: relative;
        z-index: 1;
        padding: 1.2rem;
        color: #eff4fb;
      }

      .project-meta h3 {
        font-size: 1.2rem;
      }

      .metrics {
        margin-top: 0.7rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }

      .pill {
        font-size: 0.75rem;
        padding: 0.28rem 0.56rem;
        border: 1px solid rgba(231, 237, 245, 0.36);
        border-radius: 999px;
        background: rgba(11, 20, 34, 0.32);
      }

      .cta-link {
        display: inline-flex;
        margin-top: 1.4rem;
        font-size: 0.84rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-primary);
        text-decoration: none;
        border-bottom: 1px solid currentColor;
        padding-bottom: 0.2rem;
      }

      .test-image-break {
        position: relative;
        width: 100%;
        height: 33vh;
        min-height: 220px;
        background:
          linear-gradient(rgba(7, 13, 22, 0.24), rgba(7, 13, 22, 0.24)),
          url("/AND IMG night snow lights.jpeg") center / cover no-repeat fixed;
        background-color: #0f1a2a;
        overflow: hidden;
      }

      .test-image-title-wrap {
        position: absolute;
        inset: 0;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .test-image-title {
        width: min(var(--max-width), 92vw);
        text-align: left;
        color: #ffffff;
        font-family: "Montserrat", "Avenir Next", "Segoe UI", Arial, sans-serif;
        font-weight: 700;
        font-size: clamp(1.55rem, 3vw, 2.3rem);
        line-height: 1.12;
        text-shadow: 0 2px 10px rgba(2, 6, 12, 0.5);
      }

      .leaders {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 1.2rem;
        align-items: stretch;
      }

      .leaders-image {
        border-radius: 1rem;
        overflow: hidden;
        min-height: 21rem;
        border: 1px solid var(--line);
      }

      .leaders-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .leaders-copy {
        background: var(--bg-white);
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      blockquote {
        margin: 0;
        font-size: 1.15rem;
        line-height: 1.35;
      }

      .leaders-note {
        margin-top: 0.9rem;
        color: var(--text-muted);
      }

      .gateway {
        background: #0f1a2a;
        color: #e8edf6;
        border-top: 1px solid rgba(220, 228, 240, 0.15);
      }

      .gateway .intro {
        color: #c9d4e3;
      }

      .gateway-box {
        margin-top: 1.6rem;
        border: 1px solid rgba(219, 229, 241, 0.28);
        border-radius: 1rem;
        padding: 1.5rem;
        background: rgba(8, 14, 23, 0.46);
      }

      .button {
        margin-top: 1.2rem;
        display: inline-block;
        color: #132238;
        background: #d8e3f2;
        text-decoration: none;
        font-weight: 600;
        border-radius: 999px;
        padding: 0.7rem 1.2rem;
      }

      .footer {
        background: #0f1a2a;
        color: #d9e3f2;
      }

      .newsletter {
        background: linear-gradient(180deg, #f4f6fa, #eef2f8);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        padding: 2.5rem 0;
      }

      .newsletter-wrap {
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 1.4rem;
        align-items: center;
        background: #ffffff;
        border: 1px solid #d7deea;
        border-radius: 1rem;
        padding: 1.5rem;
      }

      .newsletter-copy p {
        margin-top: 0.7rem;
        color: var(--text-muted);
        max-width: 34rem;
      }

      .newsletter-form {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        justify-content: flex-end;
      }

      .newsletter-input {
        width: min(360px, 100%);
        height: 44px;
        border-radius: 0.55rem;
        border: 1px solid #cfd9e7;
        background: #f9fbff;
        padding: 0 0.85rem;
        font-size: 0.92rem;
        color: #1a2433;
        outline: none;
      }

      .newsletter-input:focus {
        border-color: #9eb0ca;
        box-shadow: 0 0 0 2px rgba(130, 147, 174, 0.18);
      }

      .newsletter-button {
        height: 44px;
        border: 1px solid rgba(14, 24, 39, 0.18);
        background: #1b2a3f;
        color: #eaf1fb;
        border-radius: 0.55rem;
        padding: 0 1rem;
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 180ms ease, transform 180ms ease;
      }

      .newsletter-button:hover {
        background: #253750;
        transform: translateY(-1px);
      }

      .newsletter-note {
        margin-top: 0.5rem;
        color: #7a889e;
        font-size: 0.72rem;
      }

      .footer-top {
        padding: 3rem 0 2.7rem;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
        gap: 1.7rem;
        align-items: start;
      }

      .footer-grid > div:not(:first-child) {
        justify-self: start;
        text-align: left;
        margin-left: 1.6rem;
      }

      .footer-grid > div:not(:first-child) .footer-list {
        justify-items: start;
      }

      .footer-logo {
        display: block;
        width: 220px;
        max-width: 100%;
        height: auto;
        margin-top: -6px;
        filter: brightness(0) invert(1);
      }

      .footer-cta {
        margin-top: 1.6rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #172235;
        background: rgba(204, 215, 232, 0.92);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        line-height: 1;
        border: 1px solid rgba(255, 255, 255, 0.15);
        white-space: nowrap;
        transition: background-color 180ms ease, transform 180ms ease, color 180ms ease,
          box-shadow 180ms ease;
      }

      .footer-cta:hover {
        background: rgba(224, 233, 246, 1);
        color: #101b2c;
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(6, 12, 20, 0.22);
      }

      .footer-cta:focus-visible {
        outline: 2px solid rgba(234, 241, 252, 0.92);
        outline-offset: 2px;
      }

      .footer-heading {
        margin: 0 0 0.75rem;
        color: #f2f6fc;
        font-size: 0.76rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 700;
      }

      .footer-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.65rem;
      }

      .footer-link {
        color: #c9d4e7;
        text-decoration: none;
        font-size: 0.75rem;
        letter-spacing: 0.09em;
        text-transform: uppercase;
      }

      .footer-link:hover {
        color: #ffffff;
      }

      .footer-meta {
        margin: 0;
        color: #c9d4e7;
        font-size: 0.74rem;
        line-height: 1.9;
      }

      .footer-divider {
        border-top: 1px solid rgba(205, 219, 238, 0.2);
      }

      .footer-bottom {
        padding: 1.3rem 0 1.45rem;
      }

      .footer-bottom-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
      }

      .footer-copy {
        margin: 0;
        color: #aebcd4;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .footer-legal {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .footer-legal a {
        color: #c1cee3;
        text-decoration: none;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .footer-social {
        display: flex;
        justify-content: flex-end;
        gap: 0.45rem;
      }

      .social-pill {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        border: 1px solid rgba(220, 231, 246, 0.34);
        color: #e3ebf8;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
      }


      @keyframes rise {
        from {
          opacity: 0;
          transform: translateY(8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 980px) {
        .adv-grid,
        .project-grid,
        .leaders,
        .newsletter-wrap {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 680px) {
        .site-header {
          gap: 0.45rem;
          min-height: 44px;
        }

        .main-nav {
          position: static;
          gap: 0.55rem;
        }

        .menu-toggle {
          display: inline-flex;
          position: relative;
          top: -4px;
          border: 0;
          box-shadow: none;
        }

        .menu-list {
          position: absolute;
          top: calc(100% + 0.5rem);
          left: 0;
          right: auto;
          min-width: 190px;
          flex-direction: column;
          align-items: flex-start;
          gap: 0.55rem;
          padding: 0;
          max-height: 0;
          opacity: 0;
          overflow: hidden;
          transform: translateY(-8px);
          pointer-events: none;
          background: rgba(10, 16, 26, 0.82);
          border: 1px solid rgba(255, 255, 255, 0.18);
          border-radius: 0.6rem;
          transition: max-height 240ms ease, opacity 240ms ease, transform 240ms ease, padding 240ms ease;
          z-index: 220;
        }

        .menu-toggle-input:checked ~ .main-nav .menu-list {
          max-height: 320px;
          opacity: 1;
          transform: translateY(0);
          pointer-events: auto;
          padding: 0.7rem;
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars {
          background: transparent;
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars::before {
          top: 0;
          transform: rotate(45deg);
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars::after {
          top: 0;
          transform: rotate(-45deg);
        }

        .menu-link {
          font-size: 0.7rem;
        }

        .menu-cta {
          display: inline-flex;
          top: -4px;
        }

        .logo {
          width: min(38vw, 190px);
          height: auto;
          position: static;
          top: auto;
          transform: none;
          margin-left: 0.9rem;
          margin-top: -14px;
        }

        .hero {
          min-height: 76vh;
        }

        .hero-content {
          padding-top: 6rem;
        }

        .partners-wrap {
          padding: 1.8rem 0 1.6rem;
        }

        .partners-track {
          gap: 2rem;
          animation-duration: 36s;
        }

        .newsletter-form {
          flex-direction: column;
          align-items: stretch;
          justify-content: flex-start;
        }

        .newsletter-input {
          width: 100%;
        }

        .newsletter-button {
          width: 100%;
        }

        .partner-logo-box {
          width: 115px;
          height: 52px;
        }

        .partner-logo-box img {
          max-height: 36px;
        }

        .footer-grid {
          grid-template-columns: 1fr 1fr;
          gap: 1.2rem;
        }

        .footer-grid > div:not(:first-child) {
          justify-self: start;
          text-align: left;
        }

        .footer-grid > div:not(:first-child) .footer-list {
          justify-items: start;
        }

        .footer-bottom-row {
          grid-template-columns: 1fr;
          text-align: left;
        }

        .footer-legal {
          justify-content: flex-start;
        }

        .footer-social {
          justify-content: flex-start;
        }

      }
    </style>
  </head>
  <body>
    <section class="hero">
      <div class="container">
        <header class="site-header" id="home">
          <input class="menu-toggle-input" type="checkbox" id="mobile-menu-toggle" />
          <label class="menu-toggle" for="mobile-menu-toggle" aria-label="Toggle navigation menu">
            <span class="menu-toggle-bars"></span>
          </label>
          <a href="/" aria-label="Go to homepage">
            <img
              class="logo"
              src="/images/branding/equity-partners-logo-light%20small.png"
              alt="Equity Partners logo"
            />
          </a>
          <nav class="main-nav" aria-label="Primary">
            <ul class="menu-list">
              <li><a class="menu-link" href="/">Home</a></li>
              <li><a class="menu-link" href="/#about">About</a></li>
              <li><a class="menu-link" href="/#team">Team</a></li>
              <li><a class="menu-link" href="/partners">Partners</a></li>
              <li><a class="menu-link" href="/blog">Blog</a></li>
              <li><a class="menu-link" href="/test">Test</a></li>
            </ul>
            <a class="menu-cta" href="/contact">Contact Us</a>
          </nav>
        </header>
        <div class="hero-content">
          <p class="hero-kicker">ANDORRA • INVESTMENT • EXCELLENCE</p>
          <h1>Your strategic partner for Andorra real estate investments.</h1>
          <p class="subline">
            Equity Partners connects investor capital to disciplined Andorran real estate execution.
          </p>
        </div>
      </div>
    </section>

    <section class="partners-wrap" id="partners-local">
      <div class="container">
        <h2 class="partners-title">OUR LOCAL PARTNERS</h2>
      </div>
      <div class="partners-marquee" aria-label="Local partner logos">
        <div class="partners-track">
          {
            localPartnersLoop.map((partner) => (
              <div class="partner-logo-box">
                <img src={partner.logo} alt={partner.name} loading="lazy" />
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section" id="about">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">Strategic Advantage</p>
          <h2>We do not just source land. We navigate the Andorran ecosystem through delivery.</h2>
          <p class="intro">
            Our edge is practical: local connectivity, regulatory confidence, and lifecycle control that keeps execution aligned with investor priorities.
          </p>
        </div>
        <div class="adv-grid">
          {
            advantages.map((item, index) => (
              <article class="adv-card">
                <p class="adv-number">0{index + 1}</p>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section projects" id="partners">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">Featured Developments</p>
          <h2>One active project and two pipeline opportunities.</h2>
          <p class="intro">Balanced proof architecture: demonstrated execution plus visible momentum.</p>
        </div>
        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <img src={project.image} alt={project.name} />
                <div class="project-meta">
                  <h3>{project.name}</h3>
                  <div class="metrics">
                    <span class="pill">Value: {project.value}</span>
                    <span class="pill">Status: {project.status}</span>
                    <span class="pill">Sector: {project.sector}</span>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
        <a class="cta-link" href="#">View All Projects</a>
      </div>
    </section>

    <section class="test-image-break" aria-label="Andorra night landscape">
      <div class="test-image-title-wrap">
        <h2 class="test-image-title">
          Would you rather live in a tax paradise, or an actual paradise with tax advantages?
        </h2>
      </div>
    </section>

    <section class="section" id="team">
      <div class="container">
        <p class="eyebrow">Leadership Bench</p>
        <div class="leaders">
          <div class="leaders-image">
            <img
              src="https://images.unsplash.com/photo-1560179707-f14e90ef3623?auto=format&fit=crop&w=1400&q=80"
              alt="Equity Partners leadership"
            />
          </div>
          <div class="leaders-copy">
            <blockquote>
              "In Andorra, trust and execution move together. Our commitment is to deliver projects that strengthen the Principality while protecting investor confidence."
            </blockquote>
            <p class="leaders-note">Equity Partners core leadership team</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section gateway" id="contact">
      <div class="container">
        <p class="eyebrow">Investor Gateway</p>
        <h2>Ready to invest in Andorra?</h2>
        <p class="intro">
          Schedule a confidential consultation with our team to explore aligned opportunities in the Principality.
        </p>
        <div class="gateway-box">
          <p>
            Additional opportunities and detailed project materials are shared directly during private investor conversations.
          </p>
          <a class="button" href="#">Schedule Confidential Consultation</a>
        </div>
      </div>
    </section>

    <section class="section newsletter" id="newsletter">
      <div class="container">
        <p class="eyebrow">Newsletter</p>
        <div class="newsletter-wrap">
          <div class="newsletter-copy">
            <h2>Stay informed on Andorra opportunities.</h2>
            <p>Get concise updates on market shifts, pipeline milestones, and investor-relevant developments.</p>
          </div>
          <form
            class="newsletter-form"
            name="newsletter-signup"
            data-netlify="true"
            action="#"
            method="post"
          >
            <input type="hidden" name="form-name" value="newsletter-signup" />
            <label class="sr-only" for="newsletter-email">Email address</label>
            <input
              class="newsletter-input"
              id="newsletter-email"
              name="email"
              type="email"
              placeholder="Enter your email"
              required
            />
            <button class="newsletter-button" type="submit">Subscribe</button>
          </form>
        </div>
        <p class="newsletter-note">We send selective updates only. No spam.</p>
      </div>
    </section>

    <footer class="footer">
      <div class="footer-top">
        <div class="container footer-grid">
          <div>
            <img
              class="footer-logo"
              src="/images/branding/equity-partners-logo-light%20small.png"
              alt="Equity Partners Andorra Property Group"
            />
            <a class="footer-cta" href="/contact">Explore Opportunities</a>
          </div>

          <div>
            <h3 class="footer-heading">Equity Partners</h3>
            <ul class="footer-list">
              <li><a class="footer-link" href="#about">About</a></li>
              <li><a class="footer-link" href="#team">Team</a></li>
              <li><a class="footer-link" href="/partners">Partners</a></li>
              <li><a class="footer-link" href="#partners">Projects</a></li>
            </ul>
          </div>

          <div>
            <h3 class="footer-heading">Resources</h3>
            <ul class="footer-list">
              <li><a class="footer-link" href="/blog">Blog</a></li>
              <li><a class="footer-link" href="#">Market Reports</a></li>
              <li><a class="footer-link" href="#">Investment Guides</a></li>
            </ul>
          </div>

          <div>
            <h3 class="footer-heading">Contact</h3>
            <p class="footer-meta">
              Av. Meritxell 95, AD500 Andorra la Vella<br />
              +376 000 000<br />
              info@equitypartnersandorra.com<br />
              SL Reg. No. L-12345-6
            </p>
          </div>
        </div>
      </div>

      <div class="footer-divider"></div>

      <div class="footer-bottom">
        <div class="container footer-bottom-row">
          <p class="footer-copy">© {currentYear} EQUITY PARTNERS. All rights reserved.</p>
          <div class="footer-legal">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Use</a>
            <a href="#">Disclaimer</a>
          </div>
          <div class="footer-social">
            <a class="social-pill" href="#" aria-label="LinkedIn">in</a>
            <a class="social-pill" href="#" aria-label="X">X</a>
            <a class="social-pill" href="#" aria-label="YouTube">▶</a>
            <a class="social-pill" href="#" aria-label="Instagram">IG</a>
          </div>
        </div>
      </div>
    </footer>
    <script type="module">
      const root = document.body;
      const syncHeaderState = () => {
        root.classList.toggle("is-scrolled", window.scrollY > 10);
      };

      syncHeaderState();
      window.addEventListener("scroll", syncHeaderState, { passive: true });
    </script>

  </body>
</html>
