---
const currentYear = new Date().getFullYear();
const teamMembers = [
  {
    name: "Alexandre Mendez",
    role: "Managing Partner",
    image: "/01_stone copy.jpg",
    description:
      "Leads originations and investor strategy with a focus on high-conviction Andorran residential opportunities.",
  },
  {
    name: "Sofia Riba",
    role: "Head of Development",
    image: "/Ordino AND IMG day snow.webp",
    description:
      "Coordinates project execution from feasibility to delivery, ensuring timing, quality, and cost discipline.",
  },
  {
    name: "Marc Ferrer",
    role: "Regulatory & Permitting Lead",
    image: "/AND IMG night snow lights.jpeg",
    description:
      "Navigates planning pathways and compliance processes across municipalities in the Principality.",
  },
  {
    name: "Clara Duarte",
    role: "Capital & Structuring",
    image: "/ordino heights.jpg",
    description:
      "Builds investor-ready financial structures aligned with return objectives and long-term asset resilience.",
  },
  {
    name: "Jordi Casals",
    role: "Partnerships Director",
    image: "/Andorra-la-Vella.webp",
    description:
      "Maintains local institutional and commercial relationships that accelerate sourcing and execution certainty.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>About Us | Equity Partners</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap");

      :root {
        --navy: #0f1a2a;
        --navy-soft: #1f2f46;
        --slate: #5f7087;
        --slate-light: #8da0b9;
        --paper: #f4f6fa;
        --white: #ffffff;
        --line: #dbe3ee;
        --max-width: 1120px;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: "Montserrat", "Avenir Next", "Segoe UI", Arial, sans-serif;
        color: var(--navy-soft);
        background: radial-gradient(circle at 10% -10%, #eef2f8 0, var(--paper) 50%);
        line-height: 1.55;
      }

      h1, h2, h3, p { margin: 0; }

      .container {
        width: min(var(--max-width), 92vw);
        margin: 0 auto;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: nowrap;
        gap: 1.8rem;
        padding-top: 2.15rem;
        padding-bottom: 0.15rem;
        padding-left: calc((100vw - min(var(--max-width), 92vw)) / 2);
        padding-right: calc((100vw - min(var(--max-width), 92vw)) / 2);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        width: 100%;
        z-index: 220;
        background: rgba(15, 26, 42, 0.92) !important;
        border-bottom: 1px solid transparent;
        transition: padding-top 320ms ease, padding-bottom 320ms ease, background-color 320ms ease,
          backdrop-filter 320ms ease, -webkit-backdrop-filter 320ms ease, border-color 320ms ease,
          box-shadow 320ms ease;
      }

      body.is-scrolled .site-header {
        background: rgba(15, 26, 42, 0.6) !important;
        padding-top: 1.25rem;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom-color: rgba(220, 231, 246, 0.2);
        box-shadow: 0 8px 20px rgba(6, 10, 18, 0.18);
      }

      .logo {
        width: 180px;
        height: auto;
        position: relative;
        top: -12px;
        filter: brightness(0) invert(1) drop-shadow(0 1px 2px rgba(0, 0, 0, 0.5));
        transition: top 320ms ease, margin-top 320ms ease;
      }

      body.is-scrolled .logo { top: -5px; }

      .main-nav {
        display: flex;
        align-items: center;
        margin-left: auto;
        flex-wrap: nowrap;
        gap: 1.3rem;
        position: relative;
        top: -11px;
        z-index: 121;
        transition: top 320ms ease;
      }

      body.is-scrolled .main-nav { top: -4px; }

      .menu-toggle-input { display: none; }

      .menu-toggle {
        display: none;
        width: 38px;
        height: 34px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 0.45rem;
        background: transparent;
        align-items: center;
        justify-content: center;
        cursor: pointer;
      }

      .menu-toggle-bars,
      .menu-toggle-bars::before,
      .menu-toggle-bars::after {
        width: 18px;
        height: 2px;
        background: #ffffff;
      }

      .menu-toggle-bars {
        display: block;
        position: relative;
        transition: background 220ms ease;
      }

      .menu-toggle-bars::before,
      .menu-toggle-bars::after {
        content: "";
        position: absolute;
        left: 0;
        transition: transform 220ms ease, top 220ms ease;
      }

      .menu-toggle-bars::before { top: -6px; }
      .menu-toggle-bars::after { top: 6px; }

      .menu-list {
        list-style: none;
        display: flex;
        align-items: center;
        white-space: nowrap;
        gap: 1.2rem;
        margin: 0;
        padding: 0;
      }

      .menu-link {
        display: inline-flex;
        align-items: center;
        color: #ffffff;
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        font-weight: 600;
        line-height: 1;
      }

      .menu-link:hover,
      .menu-link.is-active { color: #d7e3f5; }

      .menu-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
        top: 1px;
        min-width: 126px;
        color: #172235;
        background: rgba(204, 215, 232, 0.85);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        border: 1px solid rgba(255, 255, 255, 0.15);
      }

      .menu-cta:hover { background: rgba(224, 233, 246, 0.96); }

      .hero-manifesto {
        margin-top: 4.5rem;
        min-height: 62vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        background: #e9edf4;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .hero-image {
        min-height: 62vh;
        background: url("/Ordino AND IMG day snow.webp") center / cover no-repeat;
        filter: grayscale(100%);
      }

      .hero-copy {
        display: flex;
        align-items: center;
        padding: clamp(2rem, 6vw, 4rem);
      }

      .hero-copy h1 {
        color: var(--navy);
        font-size: clamp(2rem, 4.7vw, 3.4rem);
        line-height: 1.05;
        letter-spacing: -0.01em;
      }

      .hero-copy p {
        margin-top: 1rem;
        color: var(--slate);
        max-width: 44ch;
        font-size: 1.02rem;
      }

      .section {
        padding: 4.2rem 0;
      }

      .section-header {
        max-width: 48rem;
      }

      .intro {
        margin-top: 0.9rem;
        color: var(--slate);
      }

      .philosophy {
        text-align: center;
        background: #ffffff;
      }

      .eyebrow {
        font-size: 0.74rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--slate-light);
      }

      .philosophy h2 {
        margin-top: 0.6rem;
        color: var(--navy);
        font-size: clamp(1.7rem, 3vw, 2.55rem);
        line-height: 1.15;
      }

      .philosophy-copy {
        margin: 1rem auto 0;
        max-width: 64ch;
        color: var(--slate);
      }

      .philosophy-copy p + p {
        margin-top: 0.95rem;
      }

      .advantage {
        background: linear-gradient(180deg, #f4f6fa, #eef2f8);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .advantage-grid {
        margin-top: 1.8rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .advantage-card {
        background: #ffffff;
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: 1.3rem;
      }

      .advantage-icon {
        width: 34px;
        height: 34px;
        border-radius: 999px;
        border: 1px solid #cfd8e8;
        color: #4f6079;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 600;
      }

      .advantage-card h3 {
        margin-top: 0.7rem;
        color: var(--navy);
        font-size: 1.15rem;
      }

      .advantage-card p {
        margin-top: 0.6rem;
        color: var(--slate);
      }

      .methodology {
        background: #ffffff;
      }

      .timeline {
        margin-top: 1.8rem;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.7rem;
        align-items: start;
      }

      .timeline-step {
        position: relative;
        padding-top: 1.35rem;
      }

      .timeline-step::before {
        content: "";
        position: absolute;
        top: 0.45rem;
        left: 0;
        right: 0;
        height: 1px;
        background: #d4ddea;
      }

      .timeline-step:first-child::before {
        left: 22px;
      }

      .timeline-step:last-child::before {
        right: 22px;
      }

      .timeline-dot {
        width: 12px;
        height: 12px;
        border-radius: 999px;
        background: var(--navy);
        margin-bottom: 0.75rem;
      }

      .timeline-step h3 {
        color: var(--navy);
        font-size: 1.05rem;
      }

      .timeline-step p {
        margin-top: 0.5rem;
        color: var(--slate);
        font-size: 0.92rem;
      }

      .about-cta {
        background: var(--navy);
        color: #edf3fc;
        text-align: center;
      }

      .team-intro {
        background: #ffffff;
        border-bottom: 1px solid var(--line);
      }

      .team-grid {
        margin-top: 1.9rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .team-card {
        background: #f8faff;
        border: 1px solid #d8e1ee;
        border-radius: 1rem;
        overflow: hidden;
      }

      .team-card img {
        width: 100%;
        height: 11rem;
        object-fit: cover;
        display: block;
      }

      .team-card-body {
        padding: 1rem;
      }

      .team-role {
        margin-top: 0.4rem;
        color: #8293ae;
        font-size: 0.76rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .team-description {
        margin-top: 0.6rem;
        color: var(--slate);
        font-size: 0.9rem;
        line-height: 1.5;
      }

      .about-cta h2 {
        font-size: clamp(1.45rem, 3vw, 2.2rem);
        line-height: 1.16;
      }

      .about-cta .cta-button {
        margin-top: 1.1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: var(--navy);
        text-decoration: none;
        border-radius: 0.5rem;
        padding: 0.8rem 1.1rem;
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 700;
      }

      .footer {
        background: #0f1a2a;
        color: #d9e3f2;
      }

      .footer-top {
        padding: 3rem 0 2.7rem;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
        gap: 1.7rem;
        align-items: start;
      }

      .footer-grid > div:not(:first-child) {
        justify-self: start;
        text-align: left;
        margin-left: 1.6rem;
      }

      .footer-grid > div:not(:first-child) .footer-list {
        justify-items: start;
      }

      .footer-logo {
        display: block;
        width: 220px;
        max-width: 100%;
        height: auto;
        margin-top: -6px;
        filter: brightness(0) invert(1);
      }

      .footer-cta {
        margin-top: 1.6rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #172235;
        background: rgba(204, 215, 232, 0.92);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        line-height: 1;
        border: 1px solid rgba(255, 255, 255, 0.15);
        white-space: nowrap;
      }

      .footer-heading {
        margin: 0 0 0.75rem;
        color: #f2f6fc;
        font-size: 0.76rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 700;
      }

      .footer-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.65rem;
      }

      .footer-link {
        color: #c9d4e7;
        text-decoration: none;
        font-size: 0.75rem;
        letter-spacing: 0.09em;
        text-transform: uppercase;
      }

      .footer-meta {
        margin: 0;
        color: #c9d4e7;
        font-size: 0.74rem;
        line-height: 1.9;
      }

      .footer-divider {
        border-top: 1px solid rgba(205, 219, 238, 0.2);
      }

      .footer-bottom {
        padding: 1.3rem 0 1.45rem;
      }

      .footer-bottom-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
      }

      .footer-copy {
        margin: 0;
        color: #aebcd4;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .footer-legal {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .footer-legal a {
        color: #c1cee3;
        text-decoration: none;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .footer-social {
        display: flex;
        justify-content: flex-end;
        gap: 0.45rem;
      }

      .social-pill {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        border: 1px solid rgba(220, 231, 246, 0.34);
        color: #e3ebf8;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
      }

      @media (max-width: 980px) {
        .hero-manifesto,
        .advantage-grid,
        .team-grid,
        .timeline,
        .footer-grid {
          grid-template-columns: 1fr;
        }

        .hero-image {
          min-height: 36vh;
        }
      }

      @media (max-width: 680px) {
        .site-header {
          gap: 0.45rem;
          min-height: 44px;
          padding-bottom: 0.45rem;
        }

        .main-nav {
          position: static;
          gap: 0.55rem;
        }

        .menu-toggle {
          display: inline-flex;
          position: relative;
          top: -7px;
          border: 0;
          box-shadow: none;
        }

        .menu-cta {
          display: inline-flex;
          top: -7px;
        }

        .menu-list {
          position: absolute;
          top: calc(100% + 0.5rem);
          left: 0;
          right: auto;
          min-width: 190px;
          flex-direction: column;
          align-items: flex-start;
          gap: 0.55rem;
          padding: 0;
          max-height: 0;
          opacity: 0;
          overflow: hidden;
          transform: translateY(-8px);
          pointer-events: none;
          background: rgba(10, 16, 26, 0.82);
          border: 1px solid rgba(255, 255, 255, 0.18);
          border-radius: 0.6rem;
          transition: max-height 240ms ease, opacity 240ms ease, transform 240ms ease, padding 240ms ease;
          z-index: 220;
        }

        .menu-toggle-input:checked ~ .main-nav .menu-list {
          max-height: 320px;
          opacity: 1;
          transform: translateY(0);
          pointer-events: auto;
          padding: 0.7rem;
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars { background: transparent; }
        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars::before {
          top: 0;
          transform: rotate(45deg);
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars::after {
          top: 0;
          transform: rotate(-45deg);
        }

        .logo {
          width: min(38vw, 190px);
          height: auto;
          position: static;
          top: auto;
          transform: none;
          margin-left: 0.9rem;
          margin-top: -17px;
        }

        body.is-scrolled .site-header {
          padding-bottom: 0;
        }

        body.is-scrolled .menu-toggle {
          top: -4px;
        }

        body.is-scrolled .menu-cta {
          top: -4px;
        }

        body.is-scrolled .logo {
          margin-top: -14px;
        }

        .footer-grid {
          grid-template-columns: 1fr 1fr;
          gap: 1.2rem;
        }

        .footer-grid > div:not(:first-child) {
          justify-self: start;
          text-align: left;
        }

        .footer-grid > div:not(:first-child) .footer-list {
          justify-items: start;
        }

        .footer-bottom-row {
          grid-template-columns: 1fr;
          text-align: left;
        }

        .footer-legal,
        .footer-social { justify-content: flex-start; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <input class="menu-toggle-input" type="checkbox" id="mobile-menu-toggle-about" />
      <label class="menu-toggle" for="mobile-menu-toggle-about" aria-label="Toggle navigation menu">
        <span class="menu-toggle-bars"></span>
      </label>
      <a href="/" aria-label="Go to homepage">
        <img
          class="logo"
          src="/images/branding/equity-partners-logo-light%20small.png"
          alt="Equity Partners logo"
        />
      </a>
      <nav class="main-nav" aria-label="Primary">
        <ul class="menu-list">
          <li><a class="menu-link" href="/">Home</a></li>
          <li><a class="menu-link" href="/#team">Services</a></li>
          <li><a class="menu-link is-active" href="/about">About</a></li>
          <li><a class="menu-link" href="/partners">Partners</a></li>
          <li><a class="menu-link" href="/blog">Blog</a></li>
          <li><a class="menu-link" href="/test">Test</a></li>
        </ul>
        <a class="menu-cta" href="/contact">Contact Us</a>
      </nav>
    </header>

    <section class="hero-manifesto">
      <div class="hero-image" aria-label="Andorran mountains"></div>
      <div class="hero-copy">
        <div>
          <h1>The Bridge to Andorran Opportunity.</h1>
          <p>
            By blending an international investment lens with deep local roots, we open the doors to the Principality’s most exclusive real estate assets for global capital.
          </p>
        </div>
      </div>
    </section>

    <section class="section philosophy">
      <div class="container">
        <p class="eyebrow">Our Philosophy</p>
        <h2>Global Standards. Local Execution.</h2>
        <div class="philosophy-copy">
          <p>
            We apply the same analytical rigor, governance discipline, and reporting transparency expected in major global financial centers.
          </p>
          <p>
            Every mandate is adapted to the specific operating realities of Andorra, ensuring strategic clarity without losing local execution precision.
          </p>
        </div>
      </div>
    </section>

    <section class="section advantage">
      <div class="container">
        <p class="eyebrow">Andorra Advantage</p>
        <div class="advantage-grid">
          <article class="advantage-card">
            <span class="advantage-icon">S</span>
            <h3>Stability</h3>
            <p>Low public debt and a resilient economy that supports long-term investor confidence.</p>
          </article>
          <article class="advantage-card">
            <span class="advantage-icon">L</span>
            <h3>Strategic Location</h3>
            <p>A secure European hub positioned between France and Spain with strong cross-border access.</p>
          </article>
          <article class="advantage-card">
            <span class="advantage-icon">E</span>
            <h3>Exclusivity</h3>
            <p>A high-barrier market where local access creates significant off-market potential.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section methodology">
      <div class="container">
        <p class="eyebrow">Methodology</p>
        <h2>Execution framework from origination to delivery.</h2>
        <div class="timeline">
          <article class="timeline-step">
            <div class="timeline-dot"></div>
            <h3>Sourcing</h3>
            <p>Exclusive off-market deal flow.</p>
          </article>
          <article class="timeline-step">
            <div class="timeline-dot"></div>
            <h3>Validation</h3>
            <p>Institutional-grade financial modeling.</p>
          </article>
          <article class="timeline-step">
            <div class="timeline-dot"></div>
            <h3>Permitting</h3>
            <p>Expertly navigating local planning and compliance.</p>
          </article>
          <article class="timeline-step">
            <div class="timeline-dot"></div>
            <h3>Delivery</h3>
            <p>Precision execution and asset management.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section team-intro" id="team">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">Our Team</p>
          <h2>The people behind Equity Partners.</h2>
          <p class="intro">
            A five-person team combining institutional investment standards with practical Andorran market execution.
          </p>
        </div>
        <div class="team-grid">
          {
            teamMembers.map((member) => (
              <article class="team-card">
                <img src={member.image} alt={member.name} loading="lazy" />
                <div class="team-card-body">
                  <h3>{member.name}</h3>
                  <p class="team-role">{member.role}</p>
                  <p class="team-description">{member.description}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section about-cta">
      <div class="container">
        <h2>Explore our current portfolio or discuss a strategic mandate.</h2>
        <a class="cta-button" href="/contact">Contact Our Team</a>
      </div>
    </section>

    <footer class="footer">
      <div class="footer-top">
        <div class="container footer-grid">
          <div>
            <img
              class="footer-logo"
              src="/images/branding/equity-partners-logo-light%20small.png"
              alt="Equity Partners Andorra Property Group"
            />
            <a class="footer-cta" href="/contact">Explore Opportunities</a>
          </div>

          <div>
            <h3 class="footer-heading">Equity Partners</h3>
