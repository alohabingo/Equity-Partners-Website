---
import { blogPosts } from "../../data/blogPosts";

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const currentYear = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{post.title} | Equity Partners</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Open+Sans:wght@700&display=swap");

      :root {
        --bg-paper: #f3f5f9;
        --bg-white: #ffffff;
        --text-primary: #1f2835;
        --text-muted: #5a667a;
        --text-light: #e8edf5;
        --accent: #8293ae;
        --line: #dbe1ea;
        --brand-navy: #0f1a2a;
        --max-width: 1120px;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: "Avenir Next", "Segoe UI", Arial, sans-serif;
        color: var(--text-primary);
        background: radial-gradient(circle at 10% -10%, #eef2f8 0, var(--bg-paper) 50%);
        line-height: 1.6;
      }

      h1, h2, h3, p { margin: 0; }

      .container {
        width: min(var(--max-width), 92vw);
        margin: 0 auto;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: nowrap;
        gap: 1.8rem;
        padding-top: 2.15rem;
        padding-bottom: 0.15rem;
        padding-left: calc((100vw - min(var(--max-width), 92vw)) / 2);
        padding-right: calc((100vw - min(var(--max-width), 92vw)) / 2);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        width: 100%;
        z-index: 220;
        background: rgba(15, 26, 42, 0.92) !important;
        border-bottom: 1px solid transparent;
        transition: padding-top 320ms ease, padding-bottom 320ms ease, background-color 320ms ease,
          backdrop-filter 320ms ease, -webkit-backdrop-filter 320ms ease, border-color 320ms ease,
          box-shadow 320ms ease;
      }

      body.is-scrolled .site-header {
        background: rgba(15, 26, 42, 0.6) !important;
        padding-top: 1.25rem;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom-color: rgba(220, 231, 246, 0.2);
        box-shadow: 0 8px 20px rgba(6, 10, 18, 0.18);
      }

      .logo {
        width: 180px;
        height: auto;
        position: relative;
        top: -12px;
        filter: brightness(0) invert(1) drop-shadow(0 1px 2px rgba(0, 0, 0, 0.5));
        transition: top 320ms ease;
      }

      body.is-scrolled .logo { top: -5px; }

      .main-nav {
        display: flex;
        align-items: center;
        margin-left: auto;
        flex-wrap: nowrap;
        gap: 1.3rem;
        position: relative;
        top: -11px;
        z-index: 121;
        transition: top 320ms ease;
      }

      body.is-scrolled .main-nav { top: -4px; }

      .menu-toggle-input { display: none; }

      .menu-toggle {
        display: none;
        width: 38px;
        height: 34px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 0.45rem;
        background: transparent;
        align-items: center;
        justify-content: center;
        cursor: pointer;
      }

      .menu-toggle-bars,
      .menu-toggle-bars::before,
      .menu-toggle-bars::after {
        width: 18px;
        height: 2px;
        background: #ffffff;
      }

      .menu-toggle-bars {
        display: block;
        position: relative;
        transition: background 220ms ease;
      }

      .menu-toggle-bars::before,
      .menu-toggle-bars::after {
        content: "";
        position: absolute;
        left: 0;
        transition: transform 220ms ease, top 220ms ease;
      }

      .menu-toggle-bars::before { top: -6px; }
      .menu-toggle-bars::after { top: 6px; }

      .menu-list {
        list-style: none;
        display: flex;
        align-items: center;
        white-space: nowrap;
        gap: 1.2rem;
        margin: 0;
        padding: 0;
      }

      .menu-link {
        display: inline-flex;
        align-items: center;
        color: #ffffff;
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        font-weight: 600;
        line-height: 1;
      }

      .menu-link:hover,
      .menu-link.is-active { color: #d7e3f5; }

      .menu-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
        top: 1px;
        min-width: 126px;
        color: #172235;
        background: rgba(204, 215, 232, 0.85);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        border: 1px solid rgba(255, 255, 255, 0.15);
      }

      .menu-cta:hover { background: rgba(224, 233, 246, 0.96); }

      .article-wrap {
        margin-top: 4.5rem;
        padding: 3rem 0 4rem;
      }

      .breadcrumbs {
        display: inline-flex;
        gap: 0.55rem;
        align-items: center;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        text-decoration: none;
        margin-bottom: 1.2rem;
      }

      .breadcrumbs:hover { color: #5e7393; }

      .article-shell {
        background: var(--bg-white);
        border: 1px solid var(--line);
        border-radius: 1.1rem;
        overflow: hidden;
        box-shadow: 0 18px 36px rgba(14, 25, 39, 0.08);
      }

      .article-hero {
        position: relative;
        min-height: 20rem;
        display: flex;
        align-items: flex-end;
        padding: 2.2rem;
        color: #f2f6fc;
        background: linear-gradient(180deg, rgba(8, 12, 19, 0.18), rgba(8, 12, 19, 0.72)),
          var(--hero-image) center / cover no-repeat;
      }

      .article-meta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.8rem;
        flex-wrap: wrap;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        font-size: 0.72rem;
        line-height: 1.2;
        padding: 0.28rem 0.56rem;
        border: 1px solid rgba(232, 239, 251, 0.42);
        border-radius: 999px;
        background: rgba(17, 30, 47, 0.35);
        color: #f0f5ff;
      }

      .article-hero h1 {
        font-family: "Open Sans", "Avenir Next", "Segoe UI", Arial, sans-serif;
        font-weight: 700;
        font-size: clamp(1.75rem, 4vw, 2.85rem);
        line-height: 1.1;
        max-width: 16ch;
      }

      .article-hero .subtitle {
        margin-top: 0.85rem;
        color: rgba(232, 239, 251, 0.9);
        max-width: 58ch;
      }

      .article-body {
        padding: 2.2rem;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 240px;
        gap: 2rem;
      }

      .article-content {
        max-width: 720px;
      }

      .article-section + .article-section {
        margin-top: 2rem;
      }

      .article-section h2 {
        font-size: clamp(1.28rem, 2.2vw, 1.72rem);
        line-height: 1.2;
        color: #22324a;
        margin-bottom: 0.7rem;
      }

      .article-section p + p {
        margin-top: 0.85rem;
      }

      .article-section p {
        color: #3d4b61;
      }

      .article-aside {
        border-left: 1px solid #dde5f0;
        padding-left: 1.2rem;
      }

      .aside-label {
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .aside-title {
        margin-top: 0.45rem;
        font-size: 1.05rem;
        color: #24344b;
      }

      .aside-copy {
        margin-top: 0.55rem;
        color: #607088;
        font-size: 0.9rem;
      }

      .footer {
        background: #0f1a2a;
        color: #d9e3f2;
      }

      .footer-top {
        padding: 3rem 0 2.7rem;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
        gap: 1.7rem;
        align-items: start;
      }

      .footer-grid > div:not(:first-child) {
        justify-self: start;
        text-align: left;
        margin-left: 1.6rem;
      }

      .footer-grid > div:not(:first-child) .footer-list {
        justify-items: start;
      }

      .footer-logo {
        display: block;
        width: 220px;
        max-width: 100%;
        height: auto;
        margin-top: -6px;
        filter: brightness(0) invert(1);
      }

      .footer-cta {
        margin-top: 1.6rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #172235;
        background: rgba(204, 215, 232, 0.92);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        line-height: 1;
        border: 1px solid rgba(255, 255, 255, 0.15);
        white-space: nowrap;
        transition: background-color 180ms ease, transform 180ms ease, color 180ms ease,
          box-shadow 180ms ease;
      }

      .footer-cta:hover {
        background: rgba(224, 233, 246, 1);
        color: #101b2c;
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(6, 12, 20, 0.22);
      }

      .footer-cta:focus-visible {
        outline: 2px solid rgba(234, 241, 252, 0.92);
        outline-offset: 2px;
      }

      .footer-heading {
        margin: 0 0 0.75rem;
        color: #f2f6fc;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 600;
        font-weight: 700;
      }

      .footer-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.65rem;
      }

      .footer-link {
        color: #c9d4e7;
        text-decoration: none;
        font-size: 0.75rem;
        letter-spacing: 0.09em;
        text-transform: uppercase;
      }

      .footer-link:hover {
        color: #ffffff;
      }

      .footer-meta {
        margin: 0;
        color: #c9d4e7;
        font-size: 0.74rem;
        line-height: 1.9;
      }

      .footer-divider {
        border-top: 1px solid rgba(205, 219, 238, 0.2);
      }

      .footer-bottom {
        padding: 1.3rem 0 1.45rem;
      }

      .footer-bottom-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
      }

      .footer-copy {
        margin: 0;
        color: #aebcd4;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .footer-legal {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .footer-legal a {
        color: #c1cee3;
        text-decoration: none;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .footer-social {
        display: flex;
        justify-content: flex-end;
        gap: 0.45rem;
      }

      .social-pill {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        border: 1px solid rgba(220, 231, 246, 0.34);
        color: #e3ebf8;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
      }

      @media (max-width: 980px) {
        .article-body,
        .footer-grid {
          grid-template-columns: 1fr;
        }

        .article-aside {
          border-left: 0;
          border-top: 1px solid #dde5f0;
          padding-left: 0;
          padding-top: 1rem;
        }
      }

      @media (max-width: 680px) {
        .site-header {
          gap: 0.45rem;
          min-height: 44px;
          padding-bottom: 0.45rem;
        }

        .main-nav {
          position: static;
          gap: 0.55rem;
        }

        .menu-toggle {
          display: inline-flex;
          position: relative;
          top: -7px;
          border: 0;
          box-shadow: none;
        }

        .menu-cta {
          display: inline-flex;
          top: -7px;
        }

        .menu-list {
          position: absolute;
          top: calc(100% + 0.5rem);
          left: 0;
          right: auto;
          min-width: 190px;
          flex-direction: column;
          align-items: flex-start;
          gap: 0.55rem;
          padding: 0;
          max-height: 0;
          opacity: 0;
          overflow: hidden;
          transform: translateY(-8px);
          pointer-events: none;
          background: rgba(10, 16, 26, 0.82);
          border: 1px solid rgba(255, 255, 255, 0.18);
          border-radius: 0.6rem;
          transition: max-height 240ms ease, opacity 240ms ease, transform 240ms ease, padding 240ms ease;
          z-index: 220;
        }

        .menu-toggle-input:checked ~ .main-nav .menu-list {
          max-height: 320px;
          opacity: 1;
          transform: translateY(0);
          pointer-events: auto;
          padding: 0.7rem;
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars {
          background: transparent;
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars::before {
          top: 0;
          transform: rotate(45deg);
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars::after {
          top: 0;
          transform: rotate(-45deg);
        }

        .logo {
          width: min(38vw, 190px);
          height: auto;
          position: static;
          top: auto;
          transform: none;
          margin-left: 0.9rem;
          margin-top: -17px;
        }

        .menu-link { font-size: 0.7rem; }

        body.is-scrolled .site-header { padding-bottom: 0; }
        body.is-scrolled .menu-toggle { top: -4px; }
        body.is-scrolled .menu-cta { top: -4px; }
        body.is-scrolled .logo { margin-top: -14px; }

        .article-wrap {
          margin-top: 4.5rem;
          padding: 2rem 0 3rem;
        }

        .article-hero,
        .article-body {
          padding: 1.25rem;
        }

        .footer-grid {
          grid-template-columns: 1fr 1fr;
          gap: 1.2rem;
        }

        .footer-grid > div:not(:first-child) {
          justify-self: start;
          text-align: left;
        }

        .footer-grid > div:not(:first-child) .footer-list {
          justify-items: start;
        }

        .footer-bottom-row {
          grid-template-columns: 1fr;
          text-align: left;
        }

        .footer-legal {
          justify-content: flex-start;
        }

        .footer-social {
          justify-content: flex-start;
        }
      }
    </style>
  </head>
  <body style={`--hero-image: url('${post.image}')`}>
    <header class="site-header" id="home">
      <input class="menu-toggle-input" type="checkbox" id="mobile-menu-toggle-blog-article" />
      <label class="menu-toggle" for="mobile-menu-toggle-blog-article" aria-label="Toggle navigation menu">
        <span class="menu-toggle-bars"></span>
      </label>
      <a href="/" aria-label="Go to homepage">
        <img
          class="logo"
          src="/images/branding/equity-partners-logo-light%20small.png"
          alt="Equity Partners logo"
        />
      </a>
      <nav class="main-nav" aria-label="Primary">
        <ul class="menu-list">
          <li><a class="menu-link" href="/">Home</a></li>
          <li><a class="menu-link" href="/#team">Services</a></li>
              <li><a class="menu-link" href="/about">About</a></li>
          <li><a class="menu-link" href="/partners">Partners</a></li>
          <li><a class="menu-link is-active" href="/blog">Blog</a></li>
          <li><a class="menu-link" href="/test">Test</a></li>
        </ul>
        <a class="menu-cta" href="/contact">Contact Us</a>
      </nav>
    </header>

    <main class="article-wrap">
      <div class="container">
        <a class="breadcrumbs" href="/blog">Blog / Back to Insights</a>

        <article class="article-shell">
          <header class="article-hero">
            <div>
              <div class="article-meta">
                <span class="pill">{post.date}</span>
                <span class="pill">{post.category}</span>
                <span class="pill">{post.readTime}</span>
              </div>
              <h1>{post.title}</h1>
              <p class="subtitle">{post.excerpt}</p>
            </div>
          </header>

          <div class="article-body">
            <div class="article-content">
              {
                post.sections.map((section) => (
                  <section class="article-section">
                    <h2>{section.heading}</h2>
                    {section.paragraphs.map((paragraph) => (<p>{paragraph}</p>))}
                  </section>
                ))
              }
            </div>

            <aside class="article-aside">
              <p class="aside-label">Equity Partners View</p>
              <h3 class="aside-title">Execution quality defines investment outcomes.</h3>
              <p class="aside-copy">
                In Andorra, disciplined local coordination across legal, regulatory, and delivery partners is the main
                driver of risk-adjusted performance.
              </p>
            </aside>
          </div>
        </article>
      </div>
    </main>

    <footer class="footer">
      <div class="footer-top">
        <div class="container footer-grid">
          <div>
            <img
              class="footer-logo"
              src="/images/branding/equity-partners-logo-light%20small.png"
              alt="Equity Partners Andorra Property Group"
            />
            <a class="footer-cta" href="/contact">Explore Opportunities</a>
          </div>

          <div>
            <h3 class="footer-heading">Equity Partners</h3>
            <ul class="footer-list">
              <li><a class="footer-link" href="/#about">About</a></li>
              <li><a class="footer-link" href="/#team">Team</a></li>
              <li><a class="footer-link" href="/partners">Partners</a></li>
              <li><a class="footer-link" href="/#partners">Projects</a></li>
            </ul>
          </div>

          <div>
            <h3 class="footer-heading">Resources</h3>
            <ul class="footer-list">
              <li><a class="footer-link" href="/blog">Blog</a></li>
              <li><a class="footer-link" href="#">Market Reports</a></li>
              <li><a class="footer-link" href="#">Investment Guides</a></li>
            </ul>
          </div>

          <div>
            <h3 class="footer-heading">Contact</h3>
            <p class="footer-meta">
              Av. Meritxell 95, AD500 Andorra la Vella<br />
              +376 000 000<br />
              info@equitypartnersandorra.com<br />
              SL Reg. No. L-12345-6
            </p>
          </div>
        </div>
      </div>

      <div class="footer-divider"></div>

      <div class="footer-bottom">
        <div class="container footer-bottom-row">
          <p class="footer-copy">© {currentYear} EQUITY PARTNERS. All rights reserved.</p>
          <div class="footer-legal">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Use</a>
            <a href="#">Disclaimer</a>
          </div>
          <div class="footer-social">
            <a class="social-pill" href="#" aria-label="LinkedIn">in</a>
            <a class="social-pill" href="#" aria-label="X">X</a>
            <a class="social-pill" href="#" aria-label="YouTube">▶</a>
            <a class="social-pill" href="#" aria-label="Instagram">IG</a>
          </div>
        </div>
      </div>
    </footer>

    <script type="module">
      const root = document.body;
      const syncHeaderState = () => {
        root.classList.toggle("is-scrolled", window.scrollY > 10);
      };

      syncHeaderState();
      window.addEventListener("scroll", syncHeaderState, { passive: true });
    </script>
  </body>
</html>
