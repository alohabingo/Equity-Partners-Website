---
const advantages = [
  {
    title: "Local Network",
    description:
      "Direct relationships with landowners, advisors, and Andorran operators unlock faster access to qualified opportunities.",
  },
  {
    title: "Regulatory Expertise",
    description:
      "We navigate planning, approvals, and compliance in the Principality with disciplined local execution.",
  },
  {
    title: "Lifecycle Management",
    description:
      "From sourcing through delivery, we manage project decisions end-to-end with investor clarity at every stage.",
  },
];

const currentYear = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Test Sections | Equity Partners</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Open+Sans:wght@700&display=swap");

      :root {
        --bg-paper: #f3f5f9;
        --bg-white: #ffffff;
        --text-primary: #1f2835;
        --text-muted: #5a667a;
        --text-light: #e8edf5;
        --accent: #8293ae;
        --line: #dbe1ea;
        --max-width: 1120px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Avenir Next", "Segoe UI", Arial, sans-serif;
        color: var(--text-primary);
        background: radial-gradient(circle at 10% -10%, #eef2f8 0, var(--bg-paper) 50%);
        line-height: 1.5;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      .container {
        width: min(var(--max-width), 92vw);
        margin: 0 auto;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: nowrap;
        gap: 1.8rem;
        padding-top: 2.15rem;
        padding-bottom: 0.15rem;
        padding-left: calc((100vw - min(var(--max-width), 92vw)) / 2);
        padding-right: calc((100vw - min(var(--max-width), 92vw)) / 2);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        transform: none;
        width: 100%;
        z-index: 220;
        background: rgba(15, 26, 42, 0.92) !important;
        border-bottom: 1px solid transparent;
        border-radius: 0;
        transition: padding-top 320ms ease, padding-bottom 320ms ease, background-color 320ms ease,
          backdrop-filter 320ms ease, -webkit-backdrop-filter 320ms ease, border-color 320ms ease,
          box-shadow 320ms ease;
      }

      body.is-scrolled .site-header {
        background: rgba(15, 26, 42, 0.6) !important;
        padding-top: 1.25rem;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom-color: rgba(220, 231, 246, 0.2);
        box-shadow: 0 8px 20px rgba(6, 10, 18, 0.18);
      }

      body.is-scrolled .logo {
        top: -5px;
      }

      body.is-scrolled .main-nav {
        top: -4px;
      }

      @supports not ((backdrop-filter: blur(1px))) {
        body.is-scrolled .site-header {
          background: rgba(15, 26, 42, 0.84) !important;
        }
      }

      .logo {
        width: 180px;
        height: auto;
        position: relative;
        top: -12px;
        filter: brightness(0) invert(1) drop-shadow(0 1px 2px rgba(0, 0, 0, 0.5))
          drop-shadow(0 0 10px rgba(8, 14, 23, 0.35));
        transition: top 320ms ease, margin-top 320ms ease;
      }

      .main-nav {
        display: flex;
        align-items: center;
        margin-left: auto;
        flex-wrap: nowrap;
        gap: 1.3rem;
        position: relative;
        top: -11px;
        z-index: 121;
        transition: top 320ms ease;
      }

      .menu-toggle-input {
        display: none;
      }

      .menu-toggle {
        display: none;
        width: 38px;
        height: 34px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 0.45rem;
        background: transparent;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: top 320ms ease;
      }

      .menu-toggle-bars {
        display: block;
        width: 18px;
        height: 2px;
        background: #ffffff;
        position: relative;
        transition: background 220ms ease;
      }

      .menu-toggle-bars::before,
      .menu-toggle-bars::after {
        content: "";
        position: absolute;
        left: 0;
        width: 18px;
        height: 2px;
        background: #ffffff;
        transition: transform 220ms ease, top 220ms ease;
      }

      .menu-toggle-bars::before {
        top: -6px;
      }

      .menu-toggle-bars::after {
        top: 6px;
      }

      .menu-list {
        list-style: none;
        display: flex;
        align-items: center;
        flex-wrap: nowrap;
        white-space: nowrap;
        gap: 1.2rem;
        margin: 0;
        padding: 0;
      }

      .menu-link {
        display: inline-flex;
        align-items: center;
        color: #ffffff;
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        font-weight: 600;
        line-height: 1;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
      }

      .menu-link.is-active {
        color: #d7e3f5;
      }

      .menu-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
        top: 1px;
        flex: 0 0 auto;
        min-width: 126px;
        color: #172235;
        background: rgba(204, 215, 232, 0.85);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        line-height: 1;
        border: 1px solid rgba(255, 255, 255, 0.15);
        white-space: nowrap;
        transition: background-color 180ms ease, transform 180ms ease, color 180ms ease, top 320ms ease;
      }

      .menu-cta:hover {
        background: rgba(224, 233, 246, 0.96);
        color: #101b2c;
        transform: translateY(-1px);
      }

      .menu-cta:focus-visible {
        outline: 2px solid rgba(234, 241, 252, 0.9);
        outline-offset: 2px;
      }

      .hero-content {
        margin-top: auto;
        max-width: 40rem;
        padding-top: 4.5rem;
      }

      .hero-kicker {
        margin-bottom: 1rem;
        font-size: 0.78rem;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: #b2c0d4;
      }

      h1 {
        font-family: "Open Sans", "Avenir Next", "Segoe UI", Arial, sans-serif;
        font-weight: 700;
        font-size: clamp(1.9rem, 4.3vw, 3rem);
        line-height: 1.08;
      }

      .subline {
        margin-top: 0.9rem;
        color: #cad4e4;
        font-size: clamp(0.98rem, 1.6vw, 1.15rem);
      }

      .section {
        padding: 4rem 0;
      }

      .eyebrow {
        font-size: 0.8rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.85rem;
      }

      h2 {
        font-size: clamp(1.55rem, 3vw, 2.3rem);
        line-height: 1.12;
      }

      .intro {
        margin-top: 0.9rem;
        color: var(--text-muted);
      }

      .test-section-a {
        background: linear-gradient(180deg, #f4f6fa, #edf1f7);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        margin-top: 4.5rem;
      }

      .test-cards {
        margin-top: 1.8rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .test-card {
        background: var(--bg-white);
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: 1.2rem;
      }

      .test-card h3 {
        font-size: 1.1rem;
      }

      .test-card p {
        margin-top: 0.6rem;
        color: var(--text-muted);
      }

      .test-section-b {
        background: #0f1a2a;
        color: #e8edf6;
        border-top: 1px solid rgba(220, 228, 240, 0.15);
      }

      .workflow-section {
        padding: 2.3rem 0 2.8rem;
        background: linear-gradient(180deg, #f4f6fa, #edf1f7);
      }

      .workflow-head {
        margin-bottom: 1rem;
      }

      .workflow-card {
        background: #eef2f7;
        border: 1px solid #d8e0eb;
        border-radius: 1rem;
        padding: 1.55rem;
      }

      .workflow-list {
        margin: 1.35rem 0 0;
        padding: 0;
        list-style: none;
      }

      .workflow-step {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) minmax(180px, 0.55fr);
        gap: 0.9rem;
        align-items: baseline;
        padding: 1rem 0;
        border-top: 1px solid #d8e0eb;
      }

      .workflow-step:first-child {
        border-top: 0;
      }

      .workflow-index {
        font-size: 0.7rem;
        letter-spacing: 0.09em;
        color: #8b98ad;
        min-width: 1.4rem;
      }

      .workflow-step-title {
        font-size: 1.18rem;
        line-height: 1.2;
        color: #1f2b3c;
      }

      .workflow-step-note {
        font-size: 0.73rem;
        line-height: 1.35;
        color: #7b8799;
        text-align: right;
      }

      .focus-section {
        padding: 2.4rem 0 3rem;
        background: #f2f5fa;
        border-top: 1px solid #dce3ee;
        border-bottom: 1px solid #dce3ee;
      }

      .focus-layout {
        display: grid;
        grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.25fr);
        gap: 2.6rem;
        align-items: start;
      }

      .focus-layout-stacked {
        grid-template-columns: 1fr;
        gap: 1.35rem;
      }

      .focus-layout-stacked .focus-head-wide {
        width: 100%;
      }

      .focus-layout-stacked .focus-head-wide .focus-intro {
        max-width: none;
      }

      .focus-label {
        margin: 0;
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #8a99ae;
      }

      .focus-title {
        margin-top: 0.55rem;
        font-size: clamp(1.9rem, 3.3vw, 3rem);
        line-height: 1.06;
        color: #1f2b3c;
      }

      .focus-intro {
        margin-top: 0.9rem;
        max-width: 37ch;
        color: #5e6c82;
      }

      .focus-list {
        margin: 0;
        padding: 0;
        list-style: none;
        border-top: 1px solid #dce3ee;
      }

      .focus-item {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        column-gap: 0.95rem;
        row-gap: 0.35rem;
        padding: 1.18rem 0 1.24rem;
        border-bottom: 1px solid #dce3ee;
      }

      .focus-index {
        font-size: 0.73rem;
        letter-spacing: 0.09em;
        color: #8f9db1;
        margin-top: 0.2rem;
      }

      .focus-item-title {
        font-size: 1.18rem;
        line-height: 1.22;
        color: #24344c;
      }

      .focus-item-copy {
        grid-column: 2;
        margin: 0;
        color: #66758a;
        font-size: 0.9rem;
        line-height: 1.5;
      }

      .focus-variant {
        padding: 3.2rem 0;
      }

      .focus-variant + .focus-variant {
        border-top: 1px solid #dbe3ee;
      }

      .focus-variant-a {
        background: #ffffff;
      }

      .focus-a-shell {
        border: 1px solid #d8e0ec;
        border-radius: 1rem;
        background: linear-gradient(180deg, #f9fbff, #f3f7fd);
        padding: 1.2rem;
      }

      .focus-a-head {
        max-width: 42rem;
      }

      .focus-a-accordion {
        margin-top: 1rem;
        display: grid;
        gap: 0.6rem;
      }

      .focus-a-item {
        border: 1px solid #d9e2ee;
        border-radius: 0.75rem;
        overflow: hidden;
        background: #ffffff;
      }

      .focus-a-item summary {
        list-style: none;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.95rem 1rem;
        cursor: pointer;
      }

      .focus-a-item summary::-webkit-details-marker {
        display: none;
      }

      .focus-a-index {
        color: #8f9db1;
        font-size: 0.72rem;
        letter-spacing: 0.11em;
      }

      .focus-a-item h3 {
        margin: 0;
        font-size: 1.1rem;
        line-height: 1.2;
        color: #24344c;
      }

      .focus-a-item p {
        margin: 0;
        padding: 0 1rem 0.95rem 3.3rem;
        font-size: 0.9rem;
        color: #65758d;
      }

      .focus-variant-b {
        background: linear-gradient(180deg, #f4f6fa, #edf1f7);
      }

      .focus-b-head {
        max-width: 46rem;
      }

      .focus-b-matrix {
        margin-top: 1.25rem;
        border: 1px solid #d8e0ec;
        border-radius: 0.95rem;
        overflow: hidden;
        background: #ffffff;
      }

      .focus-b-row {
        display: grid;
        grid-template-columns: minmax(220px, 0.9fr) minmax(230px, 1fr) minmax(230px, 1fr);
        gap: 1rem;
        padding: 0.9rem 1rem;
        border-top: 1px solid #e1e7f0;
        align-items: center;
      }

      .focus-b-row:first-child {
        border-top: 0;
        background: #f5f8fd;
      }

      .focus-b-col-head {
        color: #6b7c93;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .focus-b-capability {
        font-size: 1.04rem;
        color: #24344c;
        font-weight: 600;
      }

      .focus-b-text {
        color: #637389;
        font-size: 0.88rem;
        line-height: 1.45;
      }

      .focus-b-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.3rem 0.58rem;
        border-radius: 999px;
        border: 1px solid #d2dceb;
        background: #f7f9fd;
        color: #556780;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .focus-variant-c {
        background: #0f1a2a;
        color: #e9f0fb;
      }

      .focus-c-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
        gap: 1rem;
        align-items: stretch;
      }

      .focus-c-media {
        border-radius: 1rem;
        min-height: 24rem;
        background:
          linear-gradient(180deg, rgba(9, 15, 25, 0.38), rgba(9, 15, 25, 0.5)),
          url("/Ordino%20AND%20IMG%20day%20snow.webp") center / cover no-repeat;
        padding: 1.2rem;
        display: flex;
        align-items: flex-end;
      }

      .focus-c-overlay {
        max-width: 24rem;
      }

      .focus-c-overlay h2 {
        color: #ffffff;
        font-size: clamp(1.6rem, 2.9vw, 2.5rem);
      }

      .focus-c-overlay p {
        margin-top: 0.7rem;
        color: #d4deee;
      }

      .focus-c-panels {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.8rem;
      }

      .focus-c-kpi {
        background: rgba(246, 251, 255, 0.08);
        border: 1px solid rgba(214, 225, 244, 0.2);
        border-radius: 0.9rem;
        padding: 1rem;
      }

      .focus-c-kpi-value {
        color: #9fb4d2;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .focus-c-kpi h3 {
        margin-top: 0.45rem;
        color: #f4f8ff;
        font-size: 1.06rem;
      }

      .focus-c-kpi p {
        margin-top: 0.5rem;
        color: #d6e0ef;
        font-size: 0.88rem;
      }

      .focus-f-header {
        margin-bottom: 0.9rem;
      }

      .focus-f-header .focus-title {
        color: #ffffff;
      }

      .focus-f-header .focus-intro {
        max-width: none;
        width: 100%;
      }

      .focus-f-body {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
        gap: 1rem;
        align-items: stretch;
      }

      .focus-f-body .focus-c-panels {
        grid-template-columns: 1fr;
      }

      .focus-f-body .focus-c-media {
        min-height: 0;
        height: 100%;
      }

      .focus-variant-d {
        background:
          linear-gradient(180deg, rgba(12, 21, 35, 0.93), rgba(18, 30, 48, 0.94)),
          url("/AND%20IMG%20night%20snow%20lights.jpeg") center / cover no-repeat;
        color: #ebf2fc;
      }

      .focus-d-shell {
        border: 1px solid rgba(216, 227, 245, 0.22);
        border-radius: 1rem;
        overflow: hidden;
        background: rgba(10, 17, 28, 0.35);
      }

      .focus-d-header {
        padding: 1.2rem 1.2rem 1rem;
        border-bottom: 1px solid rgba(214, 226, 244, 0.18);
      }

      .focus-d-header .focus-label {
        color: #c2d0e6;
      }

      .focus-d-header .focus-title {
        color: #ffffff;
        margin-top: 0.45rem;
      }

      .focus-d-header .focus-intro {
        color: #d2deee;
      }

      .focus-d-ribbon {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0;
      }

      .focus-d-metric {
        padding: 0.95rem 1rem 1.05rem;
        border-left: 1px solid rgba(213, 224, 243, 0.16);
        background: rgba(244, 250, 255, 0.06);
      }

      .focus-d-metric:first-child {
        border-left: 0;
      }

      .focus-d-metric-label {
        color: #a8bbd8;
        font-size: 0.7rem;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .focus-d-metric h3 {
        margin-top: 0.45rem;
        color: #f5f9ff;
        font-size: 1.02rem;
        line-height: 1.2;
      }

      .focus-d-metric p {
        margin-top: 0.5rem;
        color: #d3dff0;
        font-size: 0.85rem;
        line-height: 1.45;
      }

      .focus-variant-e {
        background: #0d1727;
        color: #e9f0fb;
      }

      .focus-e-layout {
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
        gap: 1rem;
      }

      .focus-e-column {
        border: 1px solid rgba(214, 226, 245, 0.2);
        border-radius: 1rem;
        background: rgba(240, 248, 255, 0.06);
        padding: 1.2rem;
      }

      .focus-e-column .focus-label {
        color: #bccce3;
      }

      .focus-e-column .focus-title {
        color: #ffffff;
      }

      .focus-e-column .focus-intro {
        color: #d3deee;
      }

      .focus-e-stack {
        margin-top: 1rem;
        display: grid;
        gap: 0.75rem;
      }

      .focus-e-card {
        border: 1px solid rgba(213, 224, 242, 0.2);
        border-radius: 0.8rem;
        padding: 0.95rem;
        background: rgba(7, 13, 23, 0.3);
      }

      .focus-e-index {
        color: #9fb4d2;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .focus-e-card h3 {
        margin-top: 0.4rem;
        color: #f3f8ff;
        font-size: 1.03rem;
        line-height: 1.2;
      }

      .focus-e-card p {
        margin-top: 0.48rem;
        color: #d3deee;
        font-size: 0.86rem;
      }

      .focus-e-photo {
        border-radius: 0.8rem;
        min-height: 16rem;
        background:
          linear-gradient(180deg, rgba(9, 15, 25, 0.2), rgba(9, 15, 25, 0.5)),
          url("/Ordino%20AND%20IMG%20day%20snow.webp") center / cover no-repeat;
      }

      .adv-grid {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .adv-card {
        background: var(--bg-white);
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: 1.4rem;
      }

      .adv-number {
        font-size: 0.8rem;
        color: var(--accent);
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .adv-card h3 {
        margin-top: 0.5rem;
        font-size: 1.25rem;
      }

      .adv-card p {
        margin-top: 0.7rem;
        color: var(--text-muted);
      }

      .strategic-clone .section-header {
        max-width: 48rem;
      }

      .strategic-clone h2 {
        font-size: clamp(1.55rem, 3vw, 2.45rem);
        line-height: 1.12;
      }

      .strategic-clone .intro {
        margin-top: 0.9rem;
        color: var(--text-muted);
      }

      .test-image-break {
        position: relative;
        width: 100%;
        height: 33vh;
        min-height: 220px;
        background-image: url("/AND%20IMG%20night%20snow%20lights.jpeg");
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
        overflow: hidden;
      }

      .test-image-break::before {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(7, 13, 22, 0.24);
        pointer-events: none;
      }

      .test-image-title-wrap {
        position: absolute;
        inset: 0;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .test-image-title {
        width: min(var(--max-width), 92vw);
        text-align: left;
        color: #ffffff;
        font-family: "Montserrat", "Avenir Next", "Segoe UI", Arial, sans-serif;
        font-weight: 700;
        font-size: clamp(1.55rem, 3vw, 2.3rem);
        line-height: 1.12;
