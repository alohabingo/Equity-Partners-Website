---
const currentYear = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Contact | Equity Partners</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Open+Sans:wght@700&display=swap");

      :root {
        --bg-paper: #f3f5f9;
        --bg-white: #ffffff;
        --text-primary: #1f2835;
        --text-muted: #5a667a;
        --text-light: #e8edf5;
        --accent: #8293ae;
        --line: #dbe1ea;
        --max-width: 1120px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Avenir Next", "Segoe UI", Arial, sans-serif;
        color: var(--text-primary);
        background: radial-gradient(circle at 10% -10%, #eef2f8 0, var(--bg-paper) 50%);
        line-height: 1.5;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      .container {
        width: min(var(--max-width), 92vw);
        margin: 0 auto;
      }

      .hero {
        min-height: 42vh;
        padding: 2rem 0 3rem;
        background: linear-gradient(
            to bottom,
            rgba(6, 8, 12, 0.4) 0%,
            rgba(6, 8, 12, 0.26) 18%,
            rgba(6, 8, 12, 0.18) 34%,
            rgba(6, 8, 12, 0.3) 100%
          ),
          url("/hero-andorra-R2PtlkD-.jpg") center / cover no-repeat;
        color: var(--text-light);
        display: flex;
        flex-direction: column;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: nowrap;
        gap: 1.8rem;
        padding-top: 2.15rem;
        padding-bottom: 0.15rem;
        padding-left: calc((100vw - min(var(--max-width), 92vw)) / 2);
        padding-right: calc((100vw - min(var(--max-width), 92vw)) / 2);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        transform: none;
        width: 100%;
        z-index: 220;
        background: transparent !important;
        border-bottom: 1px solid transparent;
        border-radius: 0;
        transition: padding-top 320ms ease, padding-bottom 320ms ease, background-color 320ms ease,
          backdrop-filter 320ms ease, -webkit-backdrop-filter 320ms ease, border-color 320ms ease,
          box-shadow 320ms ease;
      }

      body.is-scrolled .site-header {
        background: rgba(15, 26, 42, 0.6) !important;
        padding-top: 1.25rem;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom-color: rgba(220, 231, 246, 0.2);
        box-shadow: 0 8px 20px rgba(6, 10, 18, 0.18);
      }

      @supports not ((backdrop-filter: blur(1px))) {
        body.is-scrolled .site-header {
          background: rgba(15, 26, 42, 0.84) !important;
        }
      }

      .logo {
        width: 180px;
        height: auto;
        position: relative;
        top: -5px;
        filter: brightness(0) invert(1) drop-shadow(0 1px 2px rgba(0, 0, 0, 0.5))
          drop-shadow(0 0 10px rgba(8, 14, 23, 0.35));
      }

      .main-nav {
        display: flex;
        align-items: center;
        margin-left: auto;
        flex-wrap: nowrap;
        gap: 1.3rem;
        position: relative;
        top: -4px;
        z-index: 121;
      }

      .menu-toggle-input {
        display: none;
      }

      .menu-toggle {
        display: none;
        width: 38px;
        height: 34px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 0.45rem;
        background: transparent;
        align-items: center;
        justify-content: center;
        cursor: pointer;
      }

      .menu-toggle-bars {
        display: block;
        width: 18px;
        height: 2px;
        background: #ffffff;
        position: relative;
        transition: background 220ms ease;
      }

      .menu-toggle-bars::before,
      .menu-toggle-bars::after {
        content: "";
        position: absolute;
        left: 0;
        width: 18px;
        height: 2px;
        background: #ffffff;
        transition: transform 220ms ease, top 220ms ease;
      }

      .menu-toggle-bars::before {
        top: -6px;
      }

      .menu-toggle-bars::after {
        top: 6px;
      }

      .menu-list {
        list-style: none;
        display: flex;
        align-items: center;
        flex-wrap: nowrap;
        white-space: nowrap;
        gap: 1.2rem;
        margin: 0;
        padding: 0;
      }

      .menu-link {
        display: inline-flex;
        align-items: center;
        color: #ffffff;
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        font-weight: 600;
        line-height: 1;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
      }

      .menu-link:hover {
        color: #d7e3f5;
      }

      .menu-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
        top: 1px;
        flex: 0 0 auto;
        min-width: 126px;
        color: #172235;
        background: rgba(204, 215, 232, 0.85);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        line-height: 1;
        border: 1px solid rgba(255, 255, 255, 0.15);
        white-space: nowrap;
        transition: background-color 180ms ease, transform 180ms ease, color 180ms ease;
      }

      .menu-cta:hover {
        background: rgba(224, 233, 246, 0.96);
        color: #101b2c;
        transform: translateY(-1px);
      }

      .menu-cta:focus-visible {
        outline: 2px solid rgba(234, 241, 252, 0.9);
        outline-offset: 2px;
      }

      .hero-content {
        margin-top: auto;
        max-width: 38rem;
        padding-top: 4.6rem;
      }

      .hero-kicker {
        margin-bottom: 1rem;
        font-size: 0.78rem;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: #b2c0d4;
      }

      h1 {
        font-family: "Open Sans", "Avenir Next", "Segoe UI", Arial, sans-serif;
        font-weight: 700;
        font-size: clamp(1.9rem, 4.3vw, 3rem);
        line-height: 1.08;
      }

      .subline {
        margin-top: 0.9rem;
        color: #cad4e4;
        font-size: clamp(0.98rem, 1.6vw, 1.15rem);
      }

      .section {
        padding: 4rem 0;
      }

      .eyebrow {
        font-size: 0.8rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.85rem;
      }

      h2 {
        font-size: clamp(1.55rem, 3vw, 2.3rem);
        line-height: 1.12;
      }

      .intro {
        margin-top: 0.9rem;
        color: var(--text-muted);
      }

      .contact-grid {
        margin-top: 1.9rem;
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 1rem;
      }

      .contact-card {
        background: var(--bg-white);
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: 1.3rem;
      }

      .contact-form {
        display: grid;
        gap: 0.85rem;
      }

      .field-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
      }

      .input,
      .textarea {
        width: 100%;
        border: 1px solid #cfd9e7;
        border-radius: 0.55rem;
        background: #f9fbff;
        padding: 0.72rem 0.8rem;
        font-size: 0.92rem;
        color: #1a2433;
        outline: none;
        font-family: inherit;
      }

      .input:focus,
      .textarea:focus {
        border-color: #9eb0ca;
        box-shadow: 0 0 0 2px rgba(130, 147, 174, 0.18);
      }

      .textarea {
        min-height: 130px;
        resize: vertical;
      }

      .submit {
        width: fit-content;
        height: 42px;
        border: 1px solid rgba(14, 24, 39, 0.18);
        background: #1b2a3f;
        color: #eaf1fb;
        border-radius: 0.55rem;
        padding: 0 1rem;
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 600;
        cursor: pointer;
      }

      .contact-list {
        list-style: none;
        margin: 1rem 0 0;
        padding: 0;
        display: grid;
        gap: 0.8rem;
      }

      .contact-list li {
        color: var(--text-muted);
      }

      .footer {
        background: #0f1a2a;
        color: #d9e3f2;
      }

      .footer-top {
        padding: 3rem 0 2.7rem;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
        gap: 1.7rem;
        align-items: start;
      }

      .footer-grid > div:not(:first-child) {
        justify-self: start;
        text-align: left;
        margin-left: 1.6rem;
      }

      .footer-grid > div:not(:first-child) .footer-list {
        justify-items: start;
      }

      .footer-logo {
        display: block;
        width: 220px;
        max-width: 100%;
        height: auto;
        margin-top: -6px;
        filter: brightness(0) invert(1);
      }

      .footer-cta {
        margin-top: 1.6rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #172235;
        background: rgba(204, 215, 232, 0.92);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        line-height: 1;
        border: 1px solid rgba(255, 255, 255, 0.15);
        white-space: nowrap;
      }

      .footer-heading {
        margin: 0 0 0.75rem;
        color: #f2f6fc;
        font-size: 0.76rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 700;
      }

      .footer-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.65rem;
      }

      .footer-link {
        color: #c9d4e7;
        text-decoration: none;
        font-size: 0.75rem;
        letter-spacing: 0.09em;
        text-transform: uppercase;
      }

      .footer-meta {
        margin: 0;
        color: #c9d4e7;
        font-size: 0.74rem;
        line-height: 1.9;
      }

      .footer-divider {
        border-top: 1px solid rgba(205, 219, 238, 0.2);
      }

      .footer-bottom {
        padding: 1.3rem 0 1.45rem;
      }

      .footer-bottom-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
      }

      .footer-copy {
        margin: 0;
        color: #aebcd4;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .footer-legal {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .footer-legal a {
        color: #c1cee3;
        text-decoration: none;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .footer-social {
        display: flex;
        justify-content: flex-end;
        gap: 0.45rem;
      }

      .social-pill {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        border: 1px solid rgba(220, 231, 246, 0.34);
        color: #e3ebf8;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
      }

      @media (max-width: 980px) {
        .contact-grid,
        .footer-grid {
          grid-template-columns: 1fr;
        }

        .field-row {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 680px) {
        .site-header {
          gap: 0.45rem;
          min-height: 44px;
        }

        .main-nav {
          position: static;
          gap: 0.55rem;
        }

        .menu-toggle {
          display: inline-flex;
          position: relative;
          top: -4px;
          border: 0;
          box-shadow: none;
        }

        .menu-list {
          position: absolute;
          top: calc(100% + 0.5rem);
          left: 0;
          right: auto;
          min-width: 190px;
          flex-direction: column;
          align-items: flex-start;
          gap: 0.55rem;
          padding: 0;
          max-height: 0;
          opacity: 0;
          overflow: hidden;
          transform: translateY(-8px);
          pointer-events: none;
          background: rgba(10, 16, 26, 0.82);
          border: 1px solid rgba(255, 255, 255, 0.18);
          border-radius: 0.6rem;
          transition: max-height 240ms ease, opacity 240ms ease, transform 240ms ease, padding 240ms ease;
          z-index: 220;
        }

        .menu-toggle-input:checked ~ .main-nav .menu-list {
          max-height: 320px;
          opacity: 1;
          transform: translateY(0);
          pointer-events: auto;
          padding: 0.7rem;
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars {
          background: transparent;
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars::before {
          top: 0;
          transform: rotate(45deg);
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars::after {
          top: 0;
          transform: rotate(-45deg);
        }

        .logo {
          width: min(38vw, 190px);
          height: auto;
          position: static;
          top: auto;
          transform: none;
          margin-left: 0.9rem;
          margin-top: -14px;
        }

        .menu-link {
          font-size: 0.7rem;
        }

        .menu-cta {
          display: inline-flex;
          top: -4px;
        }

        .footer-grid {
          grid-template-columns: 1fr 1fr;
          gap: 1.2rem;
        }

        .footer-grid > div:not(:first-child) {
          justify-self: start;
          text-align: left;
        }

        .footer-grid > div:not(:first-child) .footer-list {
          justify-items: start;
        }

        .footer-bottom-row {
          grid-template-columns: 1fr;
          text-align: left;
        }

        .footer-legal,
        .footer-social {
          justify-content: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <section class="hero">
      <div class="container">
        <header class="site-header" id="home">
          <input class="menu-toggle-input" type="checkbox" id="mobile-menu-toggle-contact" />
          <label class="menu-toggle" for="mobile-menu-toggle-contact" aria-label="Toggle navigation menu">
            <span class="menu-toggle-bars"></span>
          </label>
          <a href="/" aria-label="Go to homepage">
            <img
              class="logo"
              src="/images/branding/equity-partners-logo-light%20small.png"
              alt="Equity Partners logo"
            />
          </a>
          <nav class="main-nav" aria-label="Primary">
            <ul class="menu-list">
              <li><a class="menu-link" href="/">Home</a></li>
              <li><a class="menu-link" href="/#about">About</a></li>
              <li><a class="menu-link" href="/#team">Team</a></li>
              <li><a class="menu-link" href="/partners">Partners</a></li>
              <li><a class="menu-link" href="/blog">Blog</a></li>
              <li><a class="menu-link" href="/test">Test</a></li>
            </ul>
            <a class="menu-cta" href="/contact">Contact Us</a>
          </nav>
        </header>
        <div class="hero-content">
          <p class="hero-kicker">Contact</p>
          <h1>Discuss your Andorra investment strategy with our team.</h1>
          <p class="subline">
            Send us your objectives and timeline. We will follow up with a confidential response.
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <p class="eyebrow">Investor Enquiry</p>
        <h2>Tell us what you want to build.</h2>
        <p class="intro">
          We work with focused investors looking for disciplined execution in the Principality.
        </p>
        <div class="contact-grid">
          <article class="contact-card">
            <form class="contact-form" name="contact-inquiry" data-netlify="true" method="post" action="#">
              <input type="hidden" name="form-name" value="contact-inquiry" />
              <div class="field-row">
                <input class="input" type="text" name="first_name" placeholder="First name" required />
                <input class="input" type="text" name="last_name" placeholder="Last name" required />
              </div>
              <div class="field-row">
                <input class="input" type="email" name="email" placeholder="Email address" required />
                <input class="input" type="text" name="company" placeholder="Company" />
              </div>
              <textarea class="textarea" name="message" placeholder="Share your investment focus and timeline" required></textarea>
              <button class="submit" type="submit">Send Enquiry</button>
            </form>
          </article>

          <article class="contact-card">
            <p class="eyebrow">Equity Partners</p>
            <h3>Andorra Property Group</h3>
            <ul class="contact-list">
              <li>Av. Meritxell 95, AD500 Andorra la Vella</li>
              <li>+376 000 000</li>
              <li>info@equitypartnersandorra.com</li>
              <li>SL Reg. No. L-12345-6</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="footer-top">
        <div class="container footer-grid">
          <div>
            <img
              class="footer-logo"
              src="/images/branding/equity-partners-logo-light%20small.png"
              alt="Equity Partners Andorra Property Group"
            />
            <a class="footer-cta" href="/contact">Explore Opportunities</a>
          </div>

          <div>
            <h3 class="footer-heading">Equity Partners</h3>
            <ul class="footer-list">
              <li><a class="footer-link" href="/#about">About</a></li>
              <li><a class="footer-link" href="/#team">Team</a></li>
              <li><a class="footer-link" href="/partners">Partners</a></li>
              <li><a class="footer-link" href="/#partners">Projects</a></li>
            </ul>
          </div>

          <div>
            <h3 class="footer-heading">Resources</h3>
            <ul class="footer-list">
              <li><a class="footer-link" href="/blog">Blog</a></li>
              <li><a class="footer-link" href="#">Market Reports</a></li>
              <li><a class="footer-link" href="#">Investment Guides</a></li>
            </ul>
          </div>

          <div>
            <h3 class="footer-heading">Contact</h3>
            <p class="footer-meta">
              Av. Meritxell 95, AD500 Andorra la Vella<br />
              +376 000 000<br />
              info@equitypartnersandorra.com<br />
              SL Reg. No. L-12345-6
            </p>
          </div>
        </div>
      </div>

      <div class="footer-divider"></div>

      <div class="footer-bottom">
        <div class="container footer-bottom-row">
          <p class="footer-copy">© {currentYear} EQUITY PARTNERS. All rights reserved.</p>
          <div class="footer-legal">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Use</a>
            <a href="#">Disclaimer</a>
          </div>
          <div class="footer-social">
            <a class="social-pill" href="#" aria-label="LinkedIn">in</a>
            <a class="social-pill" href="#" aria-label="X">X</a>
            <a class="social-pill" href="#" aria-label="YouTube">▶</a>
            <a class="social-pill" href="#" aria-label="Instagram">IG</a>
          </div>
        </div>
      </div>
    </footer>
    <script type="module">
      const root = document.body;
      const syncHeaderState = () => {
        root.classList.toggle("is-scrolled", window.scrollY > 10);
      };

      syncHeaderState();
      window.addEventListener("scroll", syncHeaderState, { passive: true });
    </script>
  </body>
</html>
