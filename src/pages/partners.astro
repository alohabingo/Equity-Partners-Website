---
const partners = [
  {
    name: "Emindset Law",
    role: "Legal & Structuring",
    summary:
      "Local legal counsel for transaction structuring, compliance coordination, and investor protections.",
    logo: "/images/partners/Emindset LAW LOGO.png",
  },
  {
    name: "DATA Architects",
    role: "Telecom & Digital Infrastructure",
    summary:
      "Connectivity partner supporting high-reliability digital infrastructure planning and execution.",
    logo: "/images/partners/DATA LOGO.png",
  },
  {
    name: "Creand",
    role: "Financial Services",
    summary:
      "Financial counterpart support for capital flow efficiency and institutional banking coordination.",
    logo: "/images/partners/creand.webp",
  },
  {
    name: "Engel & Volkers",
    role: "Commercial Reach",
    summary:
      "Market-facing partner contributing to strategic positioning and premium demand visibility.",
    logo: "/images/partners/engel volkers logo.png",
  },
  {
    name: "Govern d'Andorra",
    role: "Regulatory Ecosystem",
    summary:
      "Alignment with the Principality framework for permitting pathways and project delivery readiness.",
    logo: "/images/partners/Govern d'Andorra logo.png",
  },
];

const currentYear = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Partners | Equity Partners</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Open+Sans:wght@700&display=swap");

      :root {
        --bg-paper: #f3f5f9;
        --bg-white: #ffffff;
        --text-primary: #1f2835;
        --text-muted: #5a667a;
        --text-light: #e8edf5;
        --accent: #8293ae;
        --line: #dbe1ea;
        --max-width: 1120px;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: "Avenir Next", "Segoe UI", Arial, sans-serif;
        color: var(--text-primary);
        background: radial-gradient(circle at 10% -10%, #eef2f8 0, var(--bg-paper) 50%);
        line-height: 1.5;
      }

      h1, h2, h3, p { margin: 0; }

      .container {
        width: min(var(--max-width), 92vw);
        margin: 0 auto;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: nowrap;
        gap: 1.8rem;
        padding-top: 2.15rem;
        padding-bottom: 0.15rem;
        padding-left: calc((100vw - min(var(--max-width), 92vw)) / 2);
        padding-right: calc((100vw - min(var(--max-width), 92vw)) / 2);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        transform: none;
        width: 100%;
        z-index: 220;
        background: rgba(15, 26, 42, 0.92) !important;
        border-bottom: 1px solid transparent;
        border-radius: 0;
        transition: padding-top 320ms ease, padding-bottom 320ms ease, background-color 320ms ease,
          backdrop-filter 320ms ease, -webkit-backdrop-filter 320ms ease, border-color 320ms ease,
          box-shadow 320ms ease;
      }

      body.is-scrolled .site-header {
        background: rgba(15, 26, 42, 0.6) !important;
        padding-top: 1.25rem;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom-color: rgba(220, 231, 246, 0.2);
        box-shadow: 0 8px 20px rgba(6, 10, 18, 0.18);
      }

      @supports not ((backdrop-filter: blur(1px))) {
        body.is-scrolled .site-header {
          background: rgba(15, 26, 42, 0.84) !important;
        }
      }

      .logo {
        width: 180px;
        height: auto;
        position: relative;
        top: -12px;
        filter: brightness(0) invert(1) drop-shadow(0 1px 2px rgba(0, 0, 0, 0.5))
          drop-shadow(0 0 10px rgba(8, 14, 23, 0.35));
      }

      .main-nav {
        display: flex;
        align-items: center;
        margin-left: auto;
        flex-wrap: nowrap;
        gap: 1.3rem;
        position: relative;
        top: -11px;
        z-index: 121;
      }

      .menu-toggle-input { display: none; }

      .menu-toggle {
        display: none;
        width: 38px;
        height: 34px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 0.45rem;
        background: transparent;
        align-items: center;
        justify-content: center;
        cursor: pointer;
      }

      .menu-toggle-bars,
      .menu-toggle-bars::before,
      .menu-toggle-bars::after {
        width: 18px;
        height: 2px;
        background: #ffffff;
      }

      .menu-toggle-bars {
        display: block;
        position: relative;
        transition: background 220ms ease;
      }

      .menu-toggle-bars::before,
      .menu-toggle-bars::after {
        content: "";
        position: absolute;
        left: 0;
        transition: transform 220ms ease, top 220ms ease;
      }

      .menu-toggle-bars::before { top: -6px; }
      .menu-toggle-bars::after { top: 6px; }

      .menu-list {
        list-style: none;
        display: flex;
        align-items: center;
        flex-wrap: nowrap;
        white-space: nowrap;
        gap: 1.2rem;
        margin: 0;
        padding: 0;
      }

      .menu-link {
        display: inline-flex;
        align-items: center;
        color: #ffffff;
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        font-weight: 600;
        line-height: 1;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
      }

      .menu-link:hover { color: #d7e3f5; }

      .menu-link.is-active { color: #d7e3f5; }

      .menu-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
        top: 1px;
        flex: 0 0 auto;
        min-width: 126px;
        color: #172235;
        background: rgba(204, 215, 232, 0.85);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        line-height: 1;
        border: 1px solid rgba(255, 255, 255, 0.15);
        white-space: nowrap;
        transition: background-color 180ms ease, transform 180ms ease, color 180ms ease;
      }

      .menu-cta:hover {
        background: rgba(224, 233, 246, 0.96);
        color: #101b2c;
        transform: translateY(-1px);
      }

      .menu-cta:focus-visible {
        outline: 2px solid rgba(234, 241, 252, 0.9);
        outline-offset: 2px;
      }

      .section { padding: 4rem 0; }

      .partner-network {
        margin-top: 4.5rem;
      }

      .eyebrow {
        font-size: 0.8rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.85rem;
      }

      h2 {
        font-size: clamp(1.55rem, 3vw, 2.3rem);
        line-height: 1.12;
      }

      .intro {
        margin-top: 0.9rem;
        color: var(--text-muted);
        max-width: 44rem;
      }

      .partners-grid {
        margin-top: 1.8rem;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }

      .partner-card {
        background: var(--bg-white);
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: 1.9rem 2rem;
        min-height: 260px;
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 1.8rem;
        align-items: center;
      }

      .partner-logo {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0;
        padding-right: 1.4rem;
        border-right: 1px solid var(--line);
      }

      .partner-logo img {
        max-height: 82px;
        max-width: 220px;
        width: auto;
        height: auto;
      }

      .partner-role {
        margin-top: 0.25rem;
        color: #33445c;
        font-size: 0.78rem;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .partner-summary {
        margin-top: 0.7rem;
        color: var(--text-muted);
        font-size: 1rem;
        max-width: 68ch;
      }

      .partner-content h3 {
        font-size: 1.35rem;
      }

      .partner-content {
        padding-left: 0.2rem;
      }

      .footer {
        background: #0f1a2a;
        color: #d9e3f2;
      }

      .footer-top { padding: 3rem 0 2.7rem; }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
        gap: 1.7rem;
        align-items: start;
      }

      .footer-grid > div:not(:first-child) {
        justify-self: start;
        text-align: left;
        margin-left: 1.6rem;
      }

      .footer-grid > div:not(:first-child) .footer-list { justify-items: start; }

      .footer-logo {
        display: block;
        width: 220px;
        max-width: 100%;
        height: auto;
        margin-top: -6px;
        filter: brightness(0) invert(1);
      }

      .footer-cta {
        margin-top: 1.6rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #172235;
        background: rgba(204, 215, 232, 0.92);
        text-decoration: none;
        font-size: 0.72rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        border-radius: 0.45rem;
        padding: 0.65rem 0.95rem;
        font-weight: 600;
        line-height: 1;
        border: 1px solid rgba(255, 255, 255, 0.15);
      }

      .footer-heading {
        margin: 0 0 0.75rem;
        color: #f2f6fc;
        font-size: 0.76rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 700;
      }

      .footer-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.65rem;
      }

      .footer-link {
        color: #c9d4e7;
        text-decoration: none;
        font-size: 0.75rem;
        letter-spacing: 0.09em;
        text-transform: uppercase;
      }

      .footer-meta {
        margin: 0;
        color: #c9d4e7;
        font-size: 0.74rem;
        line-height: 1.9;
      }

      .footer-divider { border-top: 1px solid rgba(205, 219, 238, 0.2); }

      .footer-bottom { padding: 1.3rem 0 1.45rem; }

      .footer-bottom-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
      }

      .footer-copy {
        margin: 0;
        color: #aebcd4;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .footer-legal {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .footer-legal a {
        color: #c1cee3;
        text-decoration: none;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .footer-social {
        display: flex;
        justify-content: flex-end;
        gap: 0.45rem;
      }

      .social-pill {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        border: 1px solid rgba(220, 231, 246, 0.34);
        color: #e3ebf8;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
      }

      @media (max-width: 980px) {
        .partners-grid,
        .footer-grid { grid-template-columns: 1fr; }

        .partner-card {
          grid-template-columns: 1fr;
          min-height: 0;
          padding: 1.25rem;
        }

        .partner-logo {
          min-height: 72px;
          border-right: 0;
          border-bottom: 1px solid var(--line);
          padding-right: 0;
          padding-bottom: 0.9rem;
        }

        .partner-content {
          padding-left: 0;
        }
      }

      @media (max-width: 680px) {
        .site-header {
          gap: 0.45rem;
          min-height: 44px;
          padding-bottom: 0.45rem;
        }

        .main-nav { position: static; gap: 0.55rem; }
        .menu-toggle {
          display: inline-flex;
          position: relative;
          top: -7px;
          border: 0;
          box-shadow: none;
        }

        .menu-list {
          position: absolute;
          top: calc(100% + 0.5rem);
          left: 0;
          right: auto;
          min-width: 190px;
          flex-direction: column;
          align-items: flex-start;
          gap: 0.55rem;
          padding: 0;
          max-height: 0;
          opacity: 0;
          overflow: hidden;
          transform: translateY(-8px);
          pointer-events: none;
          background: rgba(10, 16, 26, 0.82);
          border: 1px solid rgba(255, 255, 255, 0.18);
          border-radius: 0.6rem;
          transition: max-height 240ms ease, opacity 240ms ease, transform 240ms ease, padding 240ms ease;
          z-index: 220;
        }

        .menu-toggle-input:checked ~ .main-nav .menu-list {
          max-height: 320px;
          opacity: 1;
          transform: translateY(0);
          pointer-events: auto;
          padding: 0.7rem;
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars { background: transparent; }
        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars::before {
          top: 0;
          transform: rotate(45deg);
        }

        .menu-toggle-input:checked ~ .menu-toggle .menu-toggle-bars::after {
          top: 0;
          transform: rotate(-45deg);
        }

        .logo {
          width: min(38vw, 190px);
          height: auto;
          position: static;
          top: auto;
          transform: none;
          margin-left: 0.9rem;
          margin-top: -17px;
        }

        .menu-link { font-size: 0.7rem; }

        .menu-cta {
          display: inline-flex;
          top: -7px;
        }

        .footer-grid {
          grid-template-columns: 1fr 1fr;
          gap: 1.2rem;
        }

        .footer-grid > div:not(:first-child) {
          justify-self: start;
          text-align: left;
        }

        .footer-grid > div:not(:first-child) .footer-list { justify-items: start; }

        .footer-bottom-row {
          grid-template-columns: 1fr;
          text-align: left;
        }

        .footer-legal,
        .footer-social { justify-content: flex-start; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <input class="menu-toggle-input" type="checkbox" id="mobile-menu-toggle-partners" />
      <label class="menu-toggle" for="mobile-menu-toggle-partners" aria-label="Toggle navigation menu">
        <span class="menu-toggle-bars"></span>
      </label>
      <a href="/" aria-label="Go to homepage">
        <img
          class="logo"
          src="/images/branding/equity-partners-logo-light%20small.png"
          alt="Equity Partners logo"
        />
      </a>
      <nav class="main-nav" aria-label="Primary">
        <ul class="menu-list">
          <li><a class="menu-link" href="/">Home</a></li>
          <li><a class="menu-link" href="/#about">About</a></li>
          <li><a class="menu-link" href="/#team">Team</a></li>
          <li><a class="menu-link is-active" href="/partners">Partners</a></li>
          <li><a class="menu-link" href="/blog">Blog</a></li>
          <li><a class="menu-link" href="/test">Test</a></li>
        </ul>
        <a class="menu-cta" href="/contact">Contact Us</a>
      </nav>
    </header>

    <section class="section partner-network">
      <div class="container">
        <p class="eyebrow">Our Local Partners</p>
        <h2>Trusted relationships across the Andorran ecosystem.</h2>
        <p class="intro">
          Our delivery model is built on deep local partnerships that strengthen project certainty from planning to execution.
        </p>
        <div class="partners-grid">
          {
            partners.map((partner) => (
              <article class="partner-card">
                <div class="partner-logo">
                  <img src={partner.logo} alt={partner.name} loading="lazy" />
                </div>
                <div class="partner-content">
                  <h3>{partner.name}</h3>
                  <p class="partner-role">{partner.role}</p>
                  <p class="partner-summary">{partner.summary}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="footer-top">
        <div class="container footer-grid">
          <div>
            <img
              class="footer-logo"
              src="/images/branding/equity-partners-logo-light%20small.png"
              alt="Equity Partners Andorra Property Group"
            />
            <a class="footer-cta" href="/contact">Explore Opportunities</a>
          </div>

          <div>
            <h3 class="footer-heading">Equity Partners</h3>
            <ul class="footer-list">
              <li><a class="footer-link" href="/#about">About</a></li>
              <li><a class="footer-link" href="/#team">Team</a></li>
              <li><a class="footer-link" href="/partners">Partners</a></li>
              <li><a class="footer-link" href="/#partners">Projects</a></li>
            </ul>
          </div>

          <div>
            <h3 class="footer-heading">Resources</h3>
            <ul class="footer-list">
              <li><a class="footer-link" href="/blog">Blog</a></li>
              <li><a class="footer-link" href="#">Market Reports</a></li>
              <li><a class="footer-link" href="#">Investment Guides</a></li>
            </ul>
          </div>

          <div>
            <h3 class="footer-heading">Contact</h3>
            <p class="footer-meta">
              Av. Meritxell 95, AD500 Andorra la Vella<br />
              +376 000 000<br />
              info@equitypartnersandorra.com<br />
              SL Reg. No. L-12345-6
            </p>
          </div>
        </div>
      </div>

      <div class="footer-divider"></div>

      <div class="footer-bottom">
        <div class="container footer-bottom-row">
          <p class="footer-copy">© {currentYear} EQUITY PARTNERS. All rights reserved.</p>
          <div class="footer-legal">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Use</a>
            <a href="#">Disclaimer</a>
          </div>
          <div class="footer-social">
            <a class="social-pill" href="#" aria-label="LinkedIn">in</a>
            <a class="social-pill" href="#" aria-label="X">X</a>
            <a class="social-pill" href="#" aria-label="YouTube">▶</a>
            <a class="social-pill" href="#" aria-label="Instagram">IG</a>
          </div>
        </div>
      </div>
    </footer>
    <script type="module">
      const root = document.body;
      const syncHeaderState = () => {
        root.classList.toggle("is-scrolled", window.scrollY > 10);
      };

      syncHeaderState();
      window.addEventListener("scroll", syncHeaderState, { passive: true });
    </script>
  </body>
</html>
